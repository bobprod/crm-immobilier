# Configuration SMTP pour les emails
# =====================================

# Gmail Example:
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=votre-email@gmail.com
SMTP_PASSWORD=votre-mot-de-passe-app
SMTP_FROM=noreply@votre-domaine.com

# Autres providers:
# ----------------

# Outlook/Office365:
# SMTP_HOST=smtp.office365.com
# SMTP_PORT=587

# Yahoo:
# SMTP_HOST=smtp.mail.yahoo.com
# SMTP_PORT=587

# SendGrid:
# SMTP_HOST=smtp.sendgrid.net
# SMTP_PORT=587
# SMTP_USER=apikey
# SMTP_PASSWORD=votre-api-key

# Mailgun:
# SMTP_HOST=smtp.mailgun.org
# SMTP_PORT=587

# Custom SMTP:
# SMTP_HOST=smtp.votre-domaine.com
# SMTP_PORT=587 (ou 465 avec SMTP_SECURE=true)

# Notes:
# ------
# - Pour Gmail, activez "Autoriser les applications moins sécurisées" ou utilisez un "Mot de passe d'application"
# - SMTP_SECURE=true pour le port 465 (SSL), false pour 587 (TLS)
# - SMTP_FROM est l'adresse email affichée comme expéditeur
