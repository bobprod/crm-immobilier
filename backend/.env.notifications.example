# ============================================
# Smart AI Notifications - Configuration
# ============================================

# JWT Secret (for WebSocket authentication)
JWT_SECRET=your-super-secret-jwt-key-change-in-production

# Frontend URL (for WebSocket CORS)
FRONTEND_URL=http://localhost:3000

# ============================================
# Email Provider Configuration
# ============================================

# Provider: resend, sendgrid, or smtp
EMAIL_PROVIDER=resend
EMAIL_FROM=notifications@crm-immobilier.com

# Resend (Recommended - https://resend.com)
# Free tier: 3,000 emails/month
RESEND_API_KEY=re_123456789abcdefghijklmnop

# SendGrid (Alternative - https://sendgrid.com)
# Free tier: 100 emails/day
SENDGRID_API_KEY=SG.123456789abcdefghijklmnop

# SMTP Generic (Fallback)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=your-email@example.com
SMTP_PASS=your-smtp-password

# ============================================
# SMS Provider Configuration (Twilio)
# ============================================

# Twilio (https://www.twilio.com)
# Free trial: $15 credit
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_PHONE_NUMBER=+33612345678

# Twilio WhatsApp (optional)
TWILIO_WHATSAPP_NUMBER=whatsapp:+33612345678

# ============================================
# Push Notifications (Future)
# ============================================

# Firebase Cloud Messaging
# FCM_SERVER_KEY=your_fcm_server_key
# FCM_PROJECT_ID=your_fcm_project_id

# ============================================
# Comment obtenir les clés:
# ============================================

# 1. RESEND (Email - Recommandé)
#    - Aller sur https://resend.com
#    - Créer un compte gratuit
#    - Générer une API Key
#    - Copier la clé dans RESEND_API_KEY

# 2. SENDGRID (Email - Alternative)
#    - Aller sur https://sendgrid.com
#    - Créer un compte gratuit
#    - Settings > API Keys > Create API Key
#    - Copier la clé dans SENDGRID_API_KEY

# 3. TWILIO (SMS + WhatsApp)
#    - Aller sur https://www.twilio.com
#    - Créer un compte (essai gratuit $15)
#    - Console > Account SID et Auth Token
#    - Copier dans TWILIO_ACCOUNT_SID et TWILIO_AUTH_TOKEN
#    - Phone Numbers > Get a Number > Copier dans TWILIO_PHONE_NUMBER

# ============================================
# Pricing & Limites
# ============================================

# Resend (Email):
# - Free: 3,000 emails/month, 100/day
# - Pro: $20/month - 50,000 emails
# - https://resend.com/pricing

# SendGrid (Email):
# - Free: 100 emails/day
# - Essentials: $19.95/month - 50,000 emails
# - https://sendgrid.com/pricing

# Twilio (SMS):
# - Free trial: $15 credit
# - SMS France: ~€0.07/SMS
# - WhatsApp: ~€0.005/message
# - https://www.twilio.com/pricing

# ============================================
# Exemples d'utilisation
# ============================================

# Development (local):
# EMAIL_PROVIDER=resend
# RESEND_API_KEY=re_dev_key_xxx
# TWILIO_ACCOUNT_SID=AC_test_xxx (optionnel)

# Production:
# EMAIL_PROVIDER=sendgrid
# SENDGRID_API_KEY=SG.prod_key_xxx
# TWILIO_ACCOUNT_SID=AC_prod_xxx
# TWILIO_AUTH_TOKEN=prod_token_xxx
# TWILIO_PHONE_NUMBER=+33123456789
