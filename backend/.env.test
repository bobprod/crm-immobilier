# Test Environment Variables
NODE_ENV=test

# Database
DATABASE_URL=postgresql://crm_test_user:crm_test_password@localhost:5433/crm_test

# JWT Secrets (test only - not for production!)
JWT_SECRET=test_jwt_secret_key_for_testing_only_do_not_use_in_production
JWT_REFRESH_SECRET=test_jwt_refresh_secret_key_for_testing_only_do_not_use_in_production
JWT_EXPIRATION=1h
JWT_REFRESH_EXPIRATION=7d

# Server
PORT=3001
CORS_ORIGIN=http://localhost:3000,http://localhost:3003

# Rate Limiting (disabled for tests)
RATE_LIMIT_TTL=60
RATE_LIMIT_MAX=1000

# Email (disabled for tests)
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USER=test
SMTP_PASS=test
SMTP_FROM=test@crm-immobilier.com

# File Upload
MAX_FILE_SIZE=10485760
UPLOAD_PATH=./uploads/test

# API Keys (test mode)
GOOGLE_MAPS_API_KEY=test_google_maps_key
OPENAI_API_KEY=test_openai_key

# Redis (optional for tests)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# Logging
LOG_LEVEL=debug
