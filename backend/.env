# ============================================
# APPLICATION
# ============================================
NODE_ENV=development
PORT=3000
FRONTEND_URL=http://localhost:3003

# ============================================
# DATABASE (PostgreSQL) - MODIFIER ICI !
# ============================================
#DATABASE_URL="postgresql://postgres:postgres@localhost:5432/crm_immobilier?schema=public"
DATABASE_URL="postgresql://neondb_owner:npg_lbYd0ZfxRg2a@ep-lively-surf-agfn2iga-pooler.c-2.eu-central-1.aws.neon.tech/neondb?sslmode=require&channel_binding=require"


# ============================================
# JWT AUTHENTICATION
# ============================================
JWT_SECRET=dev-secret-change-in-production-12345678901234567890
JWT_REFRESH_SECRET=dev-refresh-secret-change-in-production-09876543210987654321
JWT_EXPIRATION=1h
JWT_REFRESH_EXPIRATION=7d

# ============================================
# GOOGLE OAUTH - Connexion avec Google
# ============================================
# Créer les credentials sur: https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:3000/api/auth/google/callback

# ============================================
# FACEBOOK OAUTH - Connexion avec Facebook
# ============================================
# Créer l'app sur: https://developers.facebook.com/apps/
FACEBOOK_APP_ID=
FACEBOOK_APP_SECRET=
FACEBOOK_CALLBACK_URL=http://localhost:3000/api/auth/facebook/callback

# ============================================
# EMAIL (SMTP) - Optionnel
# ============================================
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM_NAME=CRM Immobilier
SMTP_FROM_EMAIL=noreply@localhost.com

# ============================================
# TWILIO (SMS & WhatsApp) - Optionnel
# ============================================
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=
TWILIO_WHATSAPP_NUMBER=

# ============================================
# AI PROVIDERS - Optionnel
# ============================================
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GOOGLE_API_KEY=
OPENROUTER_API_KEY=
DEEPSEEK_API_KEY=

# ============================================
# EXTERNAL INTEGRATIONS - APIs Tiers
# ============================================
# Pica - Extraction de leads
PICA_API_KEY=
PICA_API_URL=https://api.pica.io

# SERP API - Scraping Google
SERP_API_KEY=
SERP_API_URL=https://serpapi.com/search

# Firecrawl - Web scraping avancé
FIRECRAWL_API_KEY=
FIRECRAWL_API_URL=https://api.firecrawl.dev

# ============================================
# LINKEDIN OAUTH - Intégration LinkedIn
# ============================================
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=
LINKEDIN_CALLBACK_URL=http://localhost:3000/api/integrations/linkedin/callback

# ============================================
# WORDPRESS INTEGRATION
# ============================================
# Configuré par utilisateur dans les paramètres
# WORDPRESS_URL=
# WORDPRESS_USERNAME=
# WORDPRESS_APP_PASSWORD=

# ============================================
# RATE LIMITING
# ============================================
THROTTLE_TTL=60000
THROTTLE_LIMIT=100

# ============================================
# CORS
# ============================================
CORS_ORIGIN=http://localhost:3003
CORS_CREDENTIALS=true
