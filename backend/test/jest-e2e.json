{
    "moduleFileExtensions": [
        "js",
        "json",
        "ts"
    ],
    "rootDir": "../",
    "testMatch": [
        "<rootDir>/test/**/*.e2e-spec.ts"
    ],
    "transform": {
        "^.+\\.(t|j)s$": "ts-jest"
    },
    "globals": {
        "ts-jest": {
            "tsconfig": "../tsconfig.jest.json"
        }
    },
    "testEnvironment": "node"
}
