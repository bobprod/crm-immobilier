# ==============================================
# CRM IMMOBILIER - ENVIRONMENT CONFIGURATION
# ==============================================

# ---------------------------
# DATABASE
# ---------------------------
DATABASE_URL="postgresql://user:password@localhost:5432/crm_immobilier?schema=public"

# ---------------------------
# SERVER
# ---------------------------
PORT=3000
NODE_ENV=development

# ---------------------------
# JWT AUTHENTICATION
# ---------------------------
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
JWT_EXPIRES_IN=7d
JWT_REFRESH_SECRET=your-super-secret-refresh-key-change-this-in-production
JWT_REFRESH_EXPIRES_IN=30d

# ---------------------------
# GOOGLE OAUTH
# ---------------------------
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_CALLBACK_URL=http://localhost:3000/api/auth/google/callback

# ---------------------------
# FACEBOOK OAUTH
# ---------------------------
FACEBOOK_APP_ID=your-facebook-app-id
FACEBOOK_APP_SECRET=your-facebook-app-secret
FACEBOOK_CALLBACK_URL=http://localhost:3000/api/auth/facebook/callback

# ---------------------------
# LINKEDIN OAUTH (À COMPLÉTER)
# ---------------------------
# LINKEDIN_CLIENT_ID=your-linkedin-client-id
# LINKEDIN_CLIENT_SECRET=your-linkedin-client-secret
# LINKEDIN_CALLBACK_URL=http://localhost:3000/api/auth/linkedin/callback

# ---------------------------
# LLM PROVIDERS API KEYS
# ---------------------------

# Anthropic Claude (Recommandé)
ANTHROPIC_API_KEY=sk-ant-api03-...

# OpenAI GPT
OPENAI_API_KEY=sk-...

# Google Gemini
GOOGLE_AI_API_KEY=AIza...

# DeepSeek (Ultra économique)
DEEPSEEK_API_KEY=sk-...

# OpenRouter (Accès à tous les modèles)
OPENROUTER_API_KEY=sk-or-...

# ---------------------------
# EMAIL / SMTP
# ---------------------------
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USER=your-email@gmail.com
MAIL_PASSWORD=your-app-password
MAIL_FROM=noreply@crm-immobilier.com

# ---------------------------
# TWILIO (SMS)
# ---------------------------
TWILIO_ACCOUNT_SID=your-twilio-account-sid
TWILIO_AUTH_TOKEN=your-twilio-auth-token
TWILIO_PHONE_NUMBER=+33123456789

# ---------------------------
# WORDPRESS INTEGRATION
# ---------------------------
WORDPRESS_API_URL=https://your-wordpress-site.com/wp-json
WORDPRESS_USERNAME=your-wordpress-username
WORDPRESS_APP_PASSWORD=your-wordpress-app-password

# ==============================================
# MARKETING & TRACKING PIXELS
# ==============================================

# ---------------------------
# META (FACEBOOK/INSTAGRAM)
# ---------------------------
# Pixel ID trouvé dans Events Manager: https://business.facebook.com/events_manager/
FACEBOOK_PIXEL_ID=123456789012345

# Conversion API Access Token (pour server-side tracking)
# Générer sur: Events Manager > Settings > Conversions API
FACEBOOK_CONVERSION_API_TOKEN=EAAxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Test Event Code (optionnel - pour debugging)
# Utilisé pour tester les événements sans impacter les données réelles
FACEBOOK_TEST_EVENT_CODE=TEST12345

# ---------------------------
# GOOGLE TAG MANAGER
# ---------------------------
# Container ID (format: GTM-XXXXXXX)
# Trouvé sur: https://tagmanager.google.com
GOOGLE_TAG_MANAGER_ID=GTM-XXXXXXX

# Server Container (optionnel - pour server-side GTM)
GTM_SERVER_CONTAINER_URL=https://gtm-server.votredomaine.com
GTM_SERVER_CONTAINER_ID=GTM-XXXXXXX

# ---------------------------
# GOOGLE ANALYTICS 4
# ---------------------------
# Measurement ID (format: G-XXXXXXXXXX)
# Trouvé sur: https://analytics.google.com > Admin > Data Streams
GA4_MEASUREMENT_ID=G-XXXXXXXXXX

# API Secret (pour Measurement Protocol - server-side tracking)
# Générer sur: Admin > Data Streams > Measurement Protocol API secrets
GA4_API_SECRET=xxxxxxxxxxxxxxxxxxxx

# ---------------------------
# GOOGLE ADS
# ---------------------------
# Conversion ID (format: AW-XXXXXXXXXX)
GOOGLE_ADS_CONVERSION_ID=AW-XXXXXXXXXX

# Conversion Labels (par type d'événement)
# Trouvés sur: Google Ads > Tools > Conversions
GOOGLE_ADS_CONVERSION_LABEL_LEAD=xxxxxxxxxxxx
GOOGLE_ADS_CONVERSION_LABEL_PURCHASE=xxxxxxxxxxxx
GOOGLE_ADS_CONVERSION_LABEL_SCHEDULE=xxxxxxxxxxxx
GOOGLE_ADS_CONVERSION_LABEL_CONTACT=xxxxxxxxxxxx

# ---------------------------
# TIKTOK PIXEL + EVENTS API
# ---------------------------
# Pixel ID trouvé dans TikTok Ads Manager > Assets > Events
TIKTOK_PIXEL_ID=XXXXXXXXXXXXX

# Access Token (pour Events API - server-side)
# Générer sur: TikTok Ads Manager > Tools > Events Manager
TIKTOK_ACCESS_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ---------------------------
# LINKEDIN ADS
# ---------------------------
# Partner ID trouvé dans LinkedIn Campaign Manager > Account Assets > Insight Tag
LINKEDIN_PARTNER_ID=123456

# Conversion IDs (par type)
# Trouvés sur: Campaign Manager > Account Assets > Conversions
LINKEDIN_CONVERSION_ID_LEAD=123456
LINKEDIN_CONVERSION_ID_CONTACT=123457
LINKEDIN_CONVERSION_ID_DOWNLOAD=123458

# Access Token (pour Conversions API - server-side)
# Générer via LinkedIn Marketing Developer Platform
LINKEDIN_ACCESS_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ---------------------------
# SNAPCHAT PIXEL (OPTIONNEL)
# ---------------------------
# SNAPCHAT_PIXEL_ID=xxxxxxxxxxxxxxxxxxxx
# SNAPCHAT_ACCESS_TOKEN=xxxxxxxxxxxxxxxxxxxx

# ---------------------------
# SERVER-SIDE TRACKING
# ---------------------------
# Provider: none | stape | gtm_server | segment | custom
SERVER_SIDE_PROVIDER=stape

# Stape.io Configuration (si provider=stape)
# URL du container Stape (domaine custom recommandé)
STAPE_CONTAINER_URL=https://tag.votredomaine.com
STAPE_API_KEY=xxxxxxxxxxxxxxxxxxxx

# Custom Endpoint (si provider=custom)
# CUSTOM_TRACKING_ENDPOINT=https://tracking.votredomaine.com/event

# ---------------------------
# FRONTEND URL
# ---------------------------
FRONTEND_URL=http://localhost:3003

# ---------------------------
# RATE LIMITING
# ---------------------------
THROTTLE_TTL=60000
THROTTLE_LIMIT=60

# ---------------------------
# CORS CONFIGURATION
# ---------------------------
CORS_ORIGIN=http://localhost:3003

# ==============================================
# NOTES DE PRODUCTION
# ==============================================
#
# 1. Google OAuth: Configurez sur https://console.cloud.google.com
# 2. Facebook OAuth: Configurez sur https://developers.facebook.com
# 3. LinkedIn OAuth: À COMPLÉTER - Flow OAuth non encore implémenté
# 4. LLM Providers: Au moins 1 provider requis (Anthropic recommandé)
# 5. Rate Limiting: Protège contre les abus (60 req/min par défaut)
# 6. Changez TOUS les secrets avant de déployer en production!
#
# ==============================================
