// ========================================
// MODULE MARKETING TRACKING + IA/ML
// ========================================

model TrackingConfig {
  id            String   @id @default(cuid())
  userId        String
  platform      String   // facebook, tiktok, ga4, gtm, etc.
  config        Json
  isActive      Boolean  @default(true)
  useServerSide Boolean  @default(false)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  
  user users @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  @@unique([userId, platform])
  @@index([userId])
  @@index([platform])
}

model TrackingEvent {
  id                    String    @id @default(cuid())
  userId                String
  eventName             String
  eventType             String
  platform              String
  sessionId             String?
  prospectId            String?
  propertyId            String?
  data                  Json?
  source                String    @default("web")
  userAgent             String?
  ipAddress             String?
  referrer              String?
  url                   String?
  timestamp             DateTime  @default(now())
  conversionProbability Float?
  leadScore             Int?
  segment               String?
  createdAt             DateTime  @default(now())
  
  user users @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  @@index([userId])
  @@index([sessionId])
  @@index([prospectId])
  @@index([timestamp])
}

model MlConfig {
  id                         String   @id @default(cuid())
  userId                     String   @unique
  mode                       String   @default("suggestion")
  enableConversionPrediction Boolean  @default(true)
  enableAnomalyDetection     Boolean  @default(true)
  enableAutoSegmentation     Boolean  @default(true)
  enableSmartAttribution     Boolean  @default(true)
  budgetAdjustmentLimit      Int?     @default(20)
  minConfidenceScore         Float?   @default(0.7)
  customRules                Json?
  createdAt                  DateTime @default(now())
  updatedAt                  DateTime @updatedAt
  
  user users @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  @@index([userId])
}

model AiSuggestion {
  id             String    @id @default(cuid())
  userId         String
  type           String
  platform       String
  campaign       String?
  currentValue   Json
  suggestedValue Json
  expectedImpact Json
  confidence     Float
  reasoning      String
  status         String    @default("pending")
  createdAt      DateTime  @default(now())
  appliedAt      DateTime?
  
  user users @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  @@index([userId])
  @@index([status])
}

model DetectedAnomaly {
  id              String   @id @default(cuid())
  userId          String
  type            String
  severity        String
  metric          String
  platform        String
  expectedValue   Float
  actualValue     Float
  deviation       Float
  description     String
  recommendations Json?
  autoFixed       Boolean  @default(false)
  detectedAt      DateTime @default(now())
  
  user users @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  @@index([userId])
}

// ============================================
// 🆕 AI USAGE METRICS MODULE (NOUVEAU)
// ============================================

model ai_usage_metrics {
  id          String   @id @default(cuid())
  userId      String
  provider    String   // openai, anthropic, google, etc.
  model       String   // gpt-4, claude-3, gemini-pro, etc.
  tokensUsed  Int
  cost        Float?
  requestType String   // completion, embedding, image_generation, etc.
  endpoint    String?  // API endpoint utilisé
  metadata    Json?    // Données additionnelles (température, max_tokens, etc.)
  timestamp   DateTime @default(now())
  createdAt   DateTime @default(now())
  
  users       users    @relation("UserAiUsageMetrics", fields: [userId], references: [id], onDelete: Cascade)
  
  @@index([userId])
  @@index([provider])
  @@index([timestamp])
  @@index([userId, timestamp])
}

// ============================================
// 🆕 CONVERSION EVENTS MODULE (NOUVEAU)
// ============================================

model conversion_events {
  id              String    @id @default(cuid())
  userId          String
  eventType       String    // lead_created, prospect_qualified, property_viewed, appointment_scheduled, deal_closed
  eventName       String?   // Nom custom de l'événement
  prospectId      String?
  propertyId      String?
  appointmentId   String?
  value           Float?    // Valeur monétaire de la conversion
  currency        String    @default("TND")
  source          String?   // Source de la conversion (organic, paid, referral, etc.)
  medium          String?   // Medium (cpc, email, social, etc.)
  campaign        String?   // Nom de la campagne
  metadata        Json?     // Données additionnelles
  timestamp       DateTime  @default(now())
  createdAt       DateTime  @default(now())
  
  users           users     @relation("UserConversionEvents", fields: [userId], references: [id], onDelete: Cascade)
  
  @@index([userId])
  @@index([eventType])
  @@index([prospectId])
  @@index([propertyId])
  @@index([timestamp])
  @@index([userId, timestamp])
  @@index([userId, eventType])
}

// ============================================
// 🆕 NOTIFICATIONS MODULE (NOUVEAU)
// ============================================

model Notification {
  id        String    @id @default(cuid())
  userId    String
  type      String    // appointment, task, lead, system, property, message
  title     String
  message   String    @db.Text
  actionUrl String?
  metadata  Json?     @default("{}")
  isRead    Boolean   @default(false)
  readAt    DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  user users @relation("UserNotifications", fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([isRead])
  @@index([type])
  @@index([createdAt])
  @@map("notifications")
}

// ============================================
// 🆕 SYNC LOGS MODULE (NOUVEAU)
// ============================================

model SyncLog {
  id           String   @id @default(cuid())
  entityType   String   // property, prospect, appointment, etc.
  entityId     String
  platform     String   // wordpress, facebook, google, etc.
  status       String   // success, error, pending
  externalId   String?
  errorMessage String?  @db.Text
  syncedAt     DateTime @default(now())
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([entityType, entityId])
  @@index([platform])
  @@index([status])
  @@index([syncedAt])
  @@map("sync_logs")
}

// ============================================
// 🆕 ACTIVITY LOGS MODULE (NOUVEAU)
// ============================================

model Activity {
  id          String   @id @default(cuid())
  userId      String
  type        String   // property_created, prospect_contacted, appointment_scheduled, etc.
  description String
  entityType  String?  // property, prospect, appointment, etc.
  entityId    String?
  metadata    Json?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user users @relation("UserActivities", fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([type])
  @@index([createdAt])
  @@index([entityType, entityId])
  @@map("activities")
}
