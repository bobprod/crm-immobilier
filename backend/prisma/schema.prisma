generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model InvestmentProject {
  id                        String                         @id @default(cuid())
  userId                    String
  tenantId                  String
  title                     String
  description               String?
  source                    InvestmentProjectSource
  sourceUrl                 String?
  sourceProjectId           String?
  city                      String
  country                   String                         @default("France")
  totalPrice                Float
  minTicket                 Float
  currency                  String                         @default("EUR")
  targetYield               Float?
  durationMonths            Int?
  propertyType              String?
  fundingProgress           Float?
  status                    InvestmentProjectStatus        @default(draft)
  importedAt                DateTime?                      @default(now())
  lastAnalyzedAt            DateTime?
  createdAt                 DateTime                       @default(now())
  updatedAt                 DateTime                       @updatedAt
  analyses                  InvestmentAnalysis[]
  documents                 documents[]
  document_investment_links document_investment_link[]

  @@map("investment_projects")
}

model InvestmentAnalysis {
  id             String            @id @default(cuid())
  projectId      String
  userId         String
  overallScore   Int
  recommendation String
  analyzedAt     DateTime?         @default(now())
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt
  project        InvestmentProject @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@map("investment_analyses")
}

model InvestmentComparison {
  id         String    @id @default(cuid())
  userId     String
  name       String?
  projectIds String[]
  criteria   Json
  results    Json
  comparedAt DateTime? @default(now())
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  @@map("investment_comparisons")
}

model InvestmentAlert {
  id                   String    @id @default(cuid())
  userId               String
  tenantId             String
  name                 String
  isActive             Boolean   @default(true)
  criteria             Json
  notificationChannels Json
  frequency            String    @default("immediate")
  lastTriggeredAt      DateTime?
  triggeredCount       Int       @default(0)
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt

  @@map("investment_alerts")
}

model ProspectingSource {
  id          String    @id @default(cuid())
  name        String
  url         String?
  type        String
  config      Json?
  lastScraped DateTime?
  isActive    Boolean   @default(true)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model agencies {
  id                    String                     @id @default(cuid())
  name                  String
  address               String?
  phone                 String?
  email                 String?
  createdAt             DateTime                   @default(now())
  updatedAt             DateTime                   @updatedAt
  apiKeys               AgencyApiKeys?
  aiCredits             AiCredits?
  aiErrorLogs           AiErrorLog[]
  aiUsages              AiUsage[]
  moduleSubscriptions   ModuleAgencySubscription[]
  properties            properties[]
  prospects             prospects[]
  providerConfigs       ProviderConfig[]           @relation("AgencyProviders")
  users                 users[]
  whatsappConfigs       WhatsAppConfig?            @relation("AgencyWhatsAppConfig")
  whatsappConversations WhatsAppConversation[]     @relation("AgencyWhatsAppConversations")
  agentProfiles         AgentProfile[]
  commissionConfig      CommissionConfig?
  annualBonusConfig     AnnualBonusConfig?
  documents             documents[]
}

model appointments {
  id             String      @id @default(cuid())
  userId         String
  prospectId     String?
  propertyId     String?
  title          String
  description    String?
  startTime      DateTime
  endTime        DateTime
  location       String?
  type           String      @default("visit")
  status         String      @default("scheduled")
  prospectType   String?
  subType        String?
  searchCriteria Json?
  mandatInfo     Json?
  profiling      Json?
  timeline       String?
  budget         Json?
  priority       String      @default("medium")
  isAllDay       Boolean     @default(false)
  reminder       Boolean     @default(true)
  reminderSent   Boolean     @default(false)
  reminderTime   Int?        @default(60)
  attendees      Json?
  notes          String?
  outcome        String?
  rating         Int?
  googleEventId  String?
  iCalUid        String?
  recurrence     Json?
  color          String?     @default("#3B82F6")
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt
  properties     properties? @relation(fields: [propertyId], references: [id])
  prospects      prospects?  @relation(fields: [prospectId], references: [id])
  users          users       @relation(fields: [userId], references: [id], onDelete: Cascade)
  tasks          tasks[]     @relation("AppointmentTasks")

  @@index([userId])
  @@index([prospectId])
  @@index([propertyId])
  @@index([startTime])
  @@index([status])
  @@index([type])
}

model campaigns {
  id             String    @id @default(cuid())
  userId         String
  name           String
  description    String?
  type           String
  status         String    @default("draft")
  prospectType   String?
  subType        String?
  searchCriteria Json?
  mandatInfo     Json?
  profiling      Json?
  timeline       String?
  budget         Json?
  content        Json
  recipients     Json
  scheduledAt    DateTime?
  sentAt         DateTime?
  stats          Json?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  users          users     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model matches {
  id             String     @id @default(cuid())
  propertyId     String
  prospectId     String
  score          Float
  reasons        Json?
  status         String     @default("pending")
  prospectType   String?
  subType        String?
  searchCriteria Json?
  mandatInfo     Json?
  profiling      Json?
  timeline       String?
  budget         Json?
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt
  properties     properties @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  prospects      prospects  @relation(fields: [prospectId], references: [id], onDelete: Cascade)

  @@unique([propertyId, prospectId])
}

model properties {
  id                  String                        @id @default(cuid())
  userId              String
  agencyId            String?
  reference           String?
  title               String
  description         String?
  type                String
  price               Float
  currency            String                        @default("TND")
  address             String?
  city                String?
  delegation          String?
  zipCode             String?
  latitude            Float?
  longitude           Float?
  bedrooms            Int?
  bathrooms           Int?
  area                Float?
  viewsCount          Int                           @default(0)
  prospectType        String?
  subType             String?
  searchCriteria      Json?
  mandatInfo          Json?
  profiling           Json?
  timeline            String?
  budget              Json?
  wpSyncId            String?
  wpSyncedAt          DateTime?
  createdAt           DateTime                      @default(now())
  updatedAt           DateTime                      @updatedAt
  assignedTo          String?
  fees                Float?
  feesPercentage      Float?
  isFeatured          Boolean                       @default(false)
  lastContactAt       DateTime?
  netPrice            Float?
  notes               String?
  ownerId             String?
  priority            PropertyPriority              @default(medium)
  tags                String[]
  wordpressId         String?
  category            PropertyCategory              @default(sale)
  images              String[]
  features            String[]
  status              PropertyStatus                @default(available)
  expirationDate      DateTime?                     // Date d'expiration de l'annonce (optionnel)
  deletedAt           DateTime?
  ownerNewId          String?
  propertySeo         PropertySeo?
  publishedProperty   PublishedProperty[]
  vitrineAnalytics    VitrineAnalytics[]
  appointments        appointments[]
  communications      communications[]
  documents           documents[]
  mandates            Mandate[]                     @relation("PropertyMandates")
  matches             matches[]
  agencies            agencies?                     @relation(fields: [agencyId], references: [id])
  assignedUser        users?                        @relation("AssignedProperties", fields: [assignedTo], references: [id])
  owner               prospects?                    @relation("PropertyOwner", fields: [ownerId], references: [id])
  ownerNew            Owner?                        @relation("OwnerProperties", fields: [ownerNewId], references: [id])
  users               users                         @relation(fields: [userId], references: [id], onDelete: Cascade)
  history             PropertyHistory[]
  prospectShown       prospect_properties_shown[]   @relation("PropertyProspectShown")
  matchedLeads        prospecting_lead_properties[] @relation("PropertyLeadMatches")
  prospecting_matches prospecting_matches[]         @relation("PropertyMatches")
  tasks               tasks[]                       @relation("PropertyTasks")
  transactions        Transaction[]                 @relation("PropertyTransactions")
  publicLeads          PublicLead[]                  @relation("PublicLeadProperty")

  @@index([priority])
  @@index([isFeatured])
  @@index([assignedTo])
  @@index([ownerId])
  @@index([ownerNewId])
  @@index([price])
  @@index([city])
  @@index([type])
  @@index([status])
  @@index([deletedAt])
  @@index([userId, status, price])
  @@index([userId, status, price], map: "properties_user_status_price_idx")
}

model PropertyHistory {
  id         String     @id @default(cuid())
  propertyId String
  userId     String
  action     String
  changes    Json?
  metadata   Json?
  createdAt  DateTime   @default(now())
  property   properties @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  user       users      @relation("PropertyHistory", fields: [userId], references: [id], onDelete: Cascade)

  @@index([propertyId])
  @@index([userId])
  @@index([action])
  @@index([createdAt])
  @@map("property_history")
}

model prospects {
  id                   String                      @id @default(cuid())
  userId               String
  agencyId             String?
  firstName            String?
  lastName             String?
  email                String?
  phone                String?
  type                 String
  currency             String                      @default("TND")
  preferences          Json?
  source               String?
  status               String                      @default("active")
  score                Int                         @default(0)
  prospectType         String?
  subType              String?
  searchCriteria       Json?
  mandatInfo           Json?
  profiling            Json?
  timeline             String?
  budget               Json?
  notes                String?
  createdAt            DateTime                    @default(now())
  updatedAt            DateTime                    @updatedAt
  deletedAt            DateTime?
  appointments         appointments[]
  communications       communications[]
  contact_validations  contact_validations[]       @relation("ProspectValidations")
  documents            documents[]
  matches              matches[]
  ownedProperties      properties[]                @relation("PropertyOwner")
  prospectHistory      ProspectHistory[]
  interactions         prospect_interactions[]     @relation("ProspectInteractions")
  preferences_details  prospect_preferences[]      @relation("ProspectPreferences")
  propertiesShown      prospect_properties_shown[] @relation("ProspectPropertiesShown")
  timelineStages       prospect_timeline[]         @relation("ProspectTimeline")
  converted_from_leads prospecting_leads[]         @relation("ConvertedProspect")
  prospecting_matches  prospecting_matches[]       @relation("ProspectMatches")
  agencies             agencies?                   @relation(fields: [agencyId], references: [id])
  users                users                       @relation(fields: [userId], references: [id], onDelete: Cascade)
  tasks                tasks[]                     @relation("ProspectTasks")
  transactions         Transaction[]               @relation("ProspectTransactions")
  publicLeads          PublicLead[]
}

model ProspectHistory {
  id         String    @id @default(cuid())
  prospectId String
  userId     String
  action     String
  changes    Json
  metadata   Json?
  createdAt  DateTime  @default(now())
  prospect   prospects @relation(fields: [prospectId], references: [id], onDelete: Cascade)
  user       users     @relation("UserProspectHistory", fields: [userId], references: [id], onDelete: Cascade)

  @@index([prospectId])
  @@index([userId])
  @@index([action])
  @@index([createdAt])
  @@map("prospect_history")
}

model users {
  id                      String                    @id @default(cuid())
  email                   String                    @unique
  password                String
  firstName               String?
  lastName                String?
  agencyId                String?
  createdAt               DateTime                  @default(now())
  updatedAt               DateTime                  @updatedAt
  wordpressPassword       String?
  wordpressUrl            String?
  wordpressUsername       String?
  role                    UserRole                  @default(AGENT)
  aiSuggestions           AiSuggestion[]
  detectedAnomalies       DetectedAnomaly[]
  mlConfig                MlConfig?
  pages                   Page[]
  publishedProperties     PublishedProperty[]
  seoBlogPosts            SeoBlogPost[]
  seoConfig               SeoConfig?
  trackingConfigs         TrackingConfig[]
  trackingEvents          TrackingEvent[]
  vitrineAnalytics        VitrineAnalytics[]
  vitrineConfig           VitrineConfig?
  activities              Activity[]                @relation("UserActivities")
  aiErrorLogs             AiErrorLog[]
  ai_generations          ai_generations[]          @relation("UserAiGenerations")
  aiOrchestrations        AiOrchestration[]
  ai_settings             ai_settings?
  aiUsages                AiUsage[]
  ai_usage_metrics        ai_usage_metrics[]        @relation("UserAiUsageMetrics")
  analytics_events        analytics_events[]        @relation("UserAnalyticsEvents")
  appointments            appointments[]
  campaigns               campaigns[]
  agentCommissions        Commission[]              @relation("AgentCommissions")
  commissions             Commission[]              @relation("UserCommissions")
  communication_templates communication_templates[] @relation("UserCommunicationTemplates")
  communications          communications[]          @relation("UserCommunications")
  contact_validations     contact_validations[]     @relation("UserContactValidations")
  conversion_events       conversion_events[]       @relation("UserConversionEvents")
  document_templates      document_templates[]      @relation("UserDocumentTemplates")
  documents               documents[]               @relation("UserDocuments")
  invoices                Invoice[]                 @relation("UserInvoices")
  llmConfig               LlmConfig?
  llmUsageLogs            LlmUsageLog[]             @relation("UserLlmUsageLogs")
  mandates                Mandate[]                 @relation("UserMandates")
  notificationPreferences NotificationPreference?   @relation("UserNotificationPreferences")
  notifications           Notification[]            @relation("UserNotifications")
  ocr_results             ocr_results[]             @relation("UserOcrResults")
  owners                  Owner[]                   @relation("UserOwners")
  payments                Payment[]                 @relation("UserPayments")
  assignedProperties      properties[]              @relation("AssignedProperties")
  properties              properties[]
  propertyHistory         PropertyHistory[]         @relation("PropertyHistory")
  prospectHistory         ProspectHistory[]         @relation("UserProspectHistory")
  prospect_interactions   prospect_interactions[]   @relation("UserProspectInteractions")
  prospecting_campaigns   prospecting_campaigns[]   @relation("UserProspectingCampaigns")
  prospecting_leads       prospecting_leads[]       @relation("UserProspectingLeads")
  prospects               prospects[]
  providerConfigs         ProviderConfig[]          @relation("UserProviders")
  providerPerformances    ProviderPerformance[]     @relation("UserProviderPerformance")
  settings                settings[]                @relation("UserSettings")
  tasks                   tasks[]                   @relation("UserTasks")
  taskBoards              TaskBoard[]               @relation("UserTaskBoards")
  planningViews           PlanningView[]            @relation("UserPlanningViews")
  toolCallLogs            ToolCallLog[]
  transactions            Transaction[]             @relation("UserTransactions")
  userAiCredits           UserAiCredits?
  userIntegrations        UserIntegration[]         @relation("UserIntegrations")
  userLlmProviders        UserLlmProvider[]
  agencies                agencies?                 @relation(fields: [agencyId], references: [id])
  whatsappConfigs         WhatsAppConfig?           @relation("UserWhatsAppConfig")
  whatsappConversations   WhatsAppConversation[]    @relation("UserWhatsAppConversations")
  whatsappMessages        WhatsAppMessage[]         @relation("UserWhatsAppMessages")
  aiChatConversations     AiChatConversation[]      @relation("UserAiChatConversations")
  agentProfile            AgentProfile?
}

model communications {
  id             String                   @id @default(cuid())
  userId         String
  type           String
  to             String
  from           String?
  subject        String?
  body           String
  status         String                   @default("sent")
  prospectType   String?
  subType        String?
  searchCriteria Json?
  mandatInfo     Json?
  profiling      Json?
  timeline       String?
  budget         Json?
  sentAt         DateTime                 @default(now())
  deliveredAt    DateTime?
  openedAt       DateTime?
  clickedAt      DateTime?
  failedReason   String?
  prospectId     String?
  propertyId     String?
  templateId     String?
  metadata       Json?
  createdAt      DateTime                 @default(now())
  updatedAt      DateTime                 @updatedAt
  properties     properties?              @relation(fields: [propertyId], references: [id])
  prospects      prospects?               @relation(fields: [prospectId], references: [id])
  template       communication_templates? @relation(fields: [templateId], references: [id])
  users          users                    @relation("UserCommunications", fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([prospectId])
  @@index([type])
  @@index([status])
}

model communication_templates {
  id             String           @id @default(cuid())
  userId         String
  name           String
  type           String
  subject        String?
  content        String
  variables      Json
  isActive       Boolean          @default(true)
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt
  users          users            @relation("UserCommunicationTemplates", fields: [userId], references: [id], onDelete: Cascade)
  communications communications[]

  @@index([userId])
  @@index([type])
}

model document_categories {
  id          String                @id @default(cuid())
  name        String
  description String?
  color       String?
  icon        String?
  parentId    String?
  createdAt   DateTime              @default(now())
  updatedAt   DateTime              @updatedAt
  parent      document_categories?  @relation("CategoryHierarchy", fields: [parentId], references: [id])
  children    document_categories[] @relation("CategoryHierarchy")
  documents   documents[]

  @@index([parentId])
}

model documents {
  id                    String                         @id @default(cuid())
  userId                String
  categoryId            String?
  name                  String
  originalName          String
  description           String?
  fileUrl               String
  filePath              String
  mimeType              String
  fileSize              Int
  extension             String
  prospectId            String?
  propertyId            String?
  relatedType           String?
  relatedId             String?
  tags                  Json?
  metadata              Json?
  isTemplate            Boolean                        @default(false)
  isPublic              Boolean                        @default(false)
  isSigned              Boolean                        @default(false)
  signedAt              DateTime?
  signedBy              String?
  ocrProcessed          Boolean                        @default(false)
  ocrText               String?
  aiGenerated           Boolean                        @default(false)
  aiGenerationId        String?
  version               Int                            @default(1)
  // New fields for real estate document management
  realEstateDocType     RealEstateDocumentType?
  agencyId              String?
  contractNumber        String?
  contractDate          DateTime?
  expirationDate        DateTime?
  contractValue         Float?
  commissionRate        Float?
  status                DocumentStatus                 @default(draft)
  validatedBy           String?
  validatedAt           DateTime?
  // Intelligence sync fields
  investmentProjectId   String?
  intelligenceSyncedAt  DateTime?
  intelligenceMetadata  Json?
  createdAt             DateTime                       @default(now())
  updatedAt             DateTime                       @updatedAt
  aiGeneration          ai_generations?                @relation(fields: [aiGenerationId], references: [id])
  category              document_categories?           @relation(fields: [categoryId], references: [id])
  properties            properties?                    @relation(fields: [propertyId], references: [id])
  prospects             prospects?                     @relation(fields: [prospectId], references: [id])
  users                 users                          @relation("UserDocuments", fields: [userId], references: [id], onDelete: Cascade)
  agency                agencies?                      @relation(fields: [agencyId], references: [id])
  investmentProject     InvestmentProject?             @relation(fields: [investmentProjectId], references: [id])
  ocr_results           ocr_results[]
  document_investment_links document_investment_link[]

  @@index([userId])
  @@index([categoryId])
  @@index([prospectId])
  @@index([propertyId])
  @@index([relatedType, relatedId])
  @@index([realEstateDocType])
  @@index([agencyId])
  @@index([investmentProjectId])
  @@index([status])
}

model document_templates {
  id                    String                     @id @default(cuid())
  userId                String
  name                  String
  description           String?
  content               String
  variables             Json
  category              String?
  mimeType              String                     @default("text/html")
  isActive              Boolean                    @default(true)
  isPublic              Boolean                    @default(false)
  usageCount            Int                        @default(0)
  // New fields for real estate templates
  realEstateDocType     RealEstateDocumentType?
  defaultValidity       Int? // in days
  requiresSignature     Boolean                    @default(false)
  templateMetadata      Json?
  createdAt             DateTime                   @default(now())
  updatedAt             DateTime                   @updatedAt
  users                 users                      @relation("UserDocumentTemplates", fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([category])
  @@index([realEstateDocType])
}

model ai_generations {
  id             String      @id @default(cuid())
  userId         String
  provider       String
  model          String
  prompt         String
  response       String
  type           String?
  documentType   String?
  tokensUsed     Int?
  cost           Float?
  temperature    Float?
  maxTokens      Int?
  status         String      @default("completed")
  prospectType   String?
  subType        String?
  searchCriteria Json?
  mandatInfo     Json?
  profiling      Json?
  timeline       String?
  budget         Json?
  errorMessage   String?
  metadata       Json?
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt
  users          users       @relation("UserAiGenerations", fields: [userId], references: [id], onDelete: Cascade)
  documents      documents[]

  @@index([userId])
  @@index([provider])
  @@index([status])
}

model ocr_results {
  id             String     @id @default(cuid())
  userId         String
  documentId     String?
  imageUrl       String
  extractedText  String
  text           String?
  language       String     @default("fra+eng")
  confidence     Float?
  processingTime Int?
  engine         String     @default("tesseract")
  metadata       Json?
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt
  document       documents? @relation(fields: [documentId], references: [id])
  users          users      @relation("UserOcrResults", fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([documentId])
}

model ai_settings {
  id                String   @id @default(cuid())
  userId            String   @unique
  defaultProvider   String   @default("openai")
  preferredProvider String?  @default("openai")
  openaiApiKey      String?
  geminiApiKey      String?
  anthropicApiKey   String?
  deepseekApiKey    String?
  openrouterApiKey  String?
  customApiKeys     Json?
  defaultModel      String?
  temperature       Float    @default(0.7)
  maxTokens         Int      @default(2000)
  preferences       Json?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  browserlessApiKey String?
  firecrawlApiKey   String?
  jinaReaderApiKey  String?
  picaApiKey        String?
  rapidApiKey       String?
  scrapingBeeApiKey String?
  serpApiKey        String?
  mistralApiKey     String?
  grokApiKey        String?
  cohereApiKey      String?
  togetherAiApiKey  String?
  replicateApiKey   String?
  perplexityApiKey  String?
  huggingfaceApiKey String?
  alephAlphaApiKey  String?
  nlpCloudApiKey    String?
  cheerioEnabled    Boolean  @default(true)
  puppeteerEnabled  Boolean  @default(true)
  users             users    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model AiOrchestration {
  id          String        @id @default(cuid())
  userId      String
  tenantId    String
  objective   String
  context     Json
  status      String
  plan        Json?
  results     Json?
  finalResult Json?
  metrics     Json?
  errors      String[]
  createdAt   DateTime      @default(now())
  completedAt DateTime?
  user        users         @relation(fields: [userId], references: [id], onDelete: Cascade)
  toolCalls   ToolCallLog[]

  @@index([userId, tenantId, status, objective, createdAt])
  @@map("ai_orchestrations")
}

model ToolCallLog {
  id              String          @id @default(cuid())
  orchestrationId String
  toolType        String
  action          String
  params          Json
  status          String
  result          Json?
  error           String?
  executionTimeMs Int?
  createdAt       DateTime        @default(now())
  completedAt     DateTime?
  userId          String?
  orchestration   AiOrchestration @relation(fields: [orchestrationId], references: [id], onDelete: Cascade)
  user            users?          @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([orchestrationId, toolType, status, createdAt])
  @@map("tool_call_logs")
}

model prospecting_campaigns {
  id             String              @id @default(cuid())
  userId         String
  name           String
  description    String?
  type           String
  config         Json
  prospectType   String?
  subType        String?
  searchCriteria Json?
  mandatInfo     Json?
  profiling      Json?
  timeline       String?
  budget         Json?
  targetCount    Int?
  foundCount     Int                 @default(0)
  matchedCount   Int                 @default(0)
  startedAt      DateTime?
  completedAt    DateTime?
  createdAt      DateTime            @default(now())
  updatedAt      DateTime            @updatedAt
  status         CampaignStatus      @default(draft)
  users          users               @relation("UserProspectingCampaigns", fields: [userId], references: [id], onDelete: Cascade)
  leads          prospecting_leads[]

  @@index([userId])
  @@index([status])
  @@index([type])
  @@index([userId, status, createdAt])
