  id                         String   @id @default(cuid())
  userId                     String   @unique
  mode                       String   @default("suggestion")
  enableConversionPrediction Boolean  @default(true)
  enableAnomalyDetection     Boolean  @default(true)
  enableAutoSegmentation     Boolean  @default(true)
  enableSmartAttribution     Boolean  @default(true)
  budgetAdjustmentLimit      Int?     @default(20)
  minConfidenceScore         Float?   @default(0.7)
  customRules                Json?
  createdAt                  DateTime @default(now())
  updatedAt                  DateTime @updatedAt
  user                       users    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model AiSuggestion {
  id             String    @id @default(cuid())
  userId         String
  type           String
  platform       String
  campaign       String?
  currentValue   Json
  suggestedValue Json
  expectedImpact Json
  confidence     Float
  reasoning      String
  status         String    @default("pending")
  createdAt      DateTime  @default(now())
  appliedAt      DateTime?
  user           users     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([status])
}

model DetectedAnomaly {
  id              String   @id @default(cuid())
  userId          String
  type            String
  severity        String
  metric          String
  platform        String
  expectedValue   Float
  actualValue     Float
  deviation       Float
  description     String
  recommendations Json?
  autoFixed       Boolean  @default(false)
  detectedAt      DateTime @default(now())
  user            users    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model ai_usage_metrics {
  id          String   @id @default(cuid())
  userId      String
  provider    String
  model       String
  tokensUsed  Int
  cost        Float?
  requestType String
  endpoint    String?
  metadata    Json?
  timestamp   DateTime @default(now())
  createdAt   DateTime @default(now())
  users       users    @relation("UserAiUsageMetrics", fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([provider])
  @@index([timestamp])
  @@index([userId, timestamp])
}

model conversion_events {
  id            String   @id @default(cuid())
  userId        String
  eventType     String
  eventName     String?
  prospectId    String?
  propertyId    String?
  appointmentId String?
  value         Float?
  currency      String   @default("TND")
  source        String?
  medium        String?
  campaign      String?
  metadata      Json?
  timestamp     DateTime @default(now())
  createdAt     DateTime @default(now())
  users         users    @relation("UserConversionEvents", fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([eventType])
  @@index([prospectId])
  @@index([propertyId])
  @@index([timestamp])
  @@index([userId, timestamp])
  @@index([userId, eventType])
}

// ============================================
// 🆕 NOTIFICATIONS MODULE (NOUVEAU)
// ============================================

model Notification {
  id        String  @id @default(cuid())
  userId    String
  type      String // appointment, task, lead, system, property, message
  title     String
  message   String  @db.Text
  actionUrl String?
  metadata  Json?   @default("{}")

  // ✅ Smart AI Notification - Canal de livraison
  channel String @default("in_app") // in_app, email, sms, push, whatsapp

  isRead Boolean   @default(false)
  readAt DateTime?

  // ✅ Smart AI Notification - Tracking
  deliveredAt DateTime? // Quand la notification a été livrée
  openedAt    DateTime? // Quand l'utilisateur a ouvert/cliqué
  deletedAt   DateTime? // Soft delete support

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user users @relation("UserNotifications", fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([isRead])
  @@index([type])
  @@index([channel]) // NEW - Pour stats par canal
  @@index([createdAt])
  @@index([deletedAt])
  @@map("notifications")
}

// ✅ Smart AI Notification - Préférences utilisateur
model NotificationPreference {
  id     String @id @default(cuid())
  userId String @unique

  // Canaux activés par type de notification
  channels Json @default("{\"appointment\":[\"in_app\",\"email\"],\"task\":[\"in_app\"],\"lead\":[\"in_app\",\"email\"],\"system\":[\"in_app\"],\"property\":[\"in_app\"],\"message\":[\"in_app\",\"push\"]}")

  // Horaires préférés (format: { "start": "09:00", "end": "18:00", "timezone": "Europe/Paris" })
  quietHours Json?

  // Fréquence maximale (ex: max 5 notifications par heure)
  maxPerHour Int @default(10)

  // AI Smart Routing activé
  aiOptimization Boolean @default(true)

  // Digest quotidien activé
  dailyDigest Boolean @default(false)
  digestTime  String? // Format: "09:00"

  // Priorités (high, medium, low)
  minPriority String @default("low")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user users @relation("UserNotificationPreferences", fields: [userId], references: [id], onDelete: Cascade)

  @@map("notification_preferences")
}

// ✅ Smart AI Notification - Intégrations API utilisateur
model UserIntegration {
  id       String @id @default(cuid())
  userId   String
  provider String // resend, sendgrid, twilio, firebase, etc.

  // Configuration (JSON chiffré contenant les clés API)
  config Json // { apiKey, accountSid, authToken, phoneNumber, etc. }

  // Métadonnées
  isActive Boolean @default(true)
  label    String? // Nom personnalisé (ex: "Twilio Production")

  // Quotas & Limites
  monthlyQuota Int? // Quota mensuel (emails, SMS)
  currentUsage Int      @default(0)
  lastResetAt  DateTime @default(now())

  // Statut
  lastTestedAt   DateTime?
  lastTestStatus String? // success, failed
  lastTestError  String?   @db.Text

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user users @relation("UserIntegrations", fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, provider])
  @@index([userId])
  @@index([provider])
  @@index([isActive])
  @@map("user_integrations")
}

// ============================================
// 🆕 SYNC LOGS MODULE (NOUVEAU)
// ============================================

model SyncLog {
  id           String   @id @default(cuid())
  entityType   String // property, prospect, appointment, etc.
  entityId     String
  platform     String // wordpress, facebook, google, etc.
  status       String // success, error, pending
  externalId   String?
  errorMessage String?  @db.Text
  syncedAt     DateTime @default(now())
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([entityType, entityId])
  @@index([platform])
  @@index([status])
  @@index([syncedAt])
  @@map("sync_logs")
}

// ============================================
// 🆕 ACTIVITY LOGS MODULE (NOUVEAU)
// ============================================

model Activity {
  id          String   @id @default(cuid())
  userId      String
  type        String // property_created, prospect_contacted, appointment_scheduled, etc.
  description String
  entityType  String? // property, prospect, appointment, etc.
  entityId    String?
  metadata    Json?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user users @relation("UserActivities", fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([type])
  @@index([createdAt])
  @@index([entityType, entityId])
  @@map("activities")
}

// ============================================
// 🆕 OWNERS MODULE (Propriétaires)
// ============================================

model Owner {
  id        String   @id @default(cuid())
  userId    String
  firstName String
  lastName  String
  email     String?
  phone     String?
  address   String?
  city      String?
  zipCode   String?
  country   String?  @default("Tunisie")
  taxId     String? // Numéro fiscal
  idCard    String? // CIN ou autre
  notes     String?  @db.Text
  metadata  Json?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user       users        @relation("UserOwners", fields: [userId], references: [id], onDelete: Cascade)
  mandates   Mandate[]
  properties properties[] @relation("OwnerProperties")
  invoices   Invoice[]

  @@index([userId])
  @@index([email])
  @@index([phone])
  @@map("owners")
}

// ============================================
// 🆕 MANDATES MODULE (Mandats)
// ============================================

model Mandate {
  id                 String          @id @default(cuid())
  userId             String
  ownerId            String
  propertyId         String?
  reference          String          @unique
  type               MandateType
  category           MandateCategory
  status             MandateStatus   @default(active)
  startDate          DateTime
  endDate            DateTime
  price              Float
  currency           String          @default("TND")
  commission         Float
  commissionType     String          @default("percentage") // percentage, fixed
  exclusivityBonus   Float?
  terms              String?         @db.Text
  notes              String?         @db.Text
  documentUrl        String?
  signedAt           DateTime?
  cancelledAt        DateTime?
  cancellationReason String?         @db.Text
  metadata           Json?
  createdAt          DateTime        @default(now())
  updatedAt          DateTime        @updatedAt

  user         users         @relation("UserMandates", fields: [userId], references: [id], onDelete: Cascade)
  owner        Owner         @relation(fields: [ownerId], references: [id], onDelete: Restrict)
  property     properties?   @relation("PropertyMandates", fields: [propertyId], references: [id], onDelete: SetNull)
  transactions Transaction[]

  @@index([userId])
  @@index([ownerId])
  @@index([propertyId])
  @@index([status])
  @@index([endDate])
  @@index([reference])
  @@map("mandates")
}

// ============================================
// 🆕 TRANSACTIONS MODULE (Transactions de vente/location)
// ============================================

model Transaction {
  id               String            @id @default(cuid())
  userId           String
  propertyId       String
  prospectId       String?
  mandateId        String?
  reference        String            @unique
  type             TransactionType
  status           TransactionStatus @default(offer_received)
  offerPrice       Float?
  negotiatedPrice  Float?
  finalPrice       Float?
  currency         String            @default("TND")
  depositAmount    Float?
  depositPaidAt    DateTime?
  offerDate        DateTime?
  promiseDate      DateTime?
  compromisDate    DateTime?
  finalDeedDate    DateTime?
  estimatedClosing DateTime?
  actualClosing    DateTime?
  buyerName        String?
  buyerEmail       String?
  buyerPhone       String?
  notes            String?           @db.Text
  notaryName       String?
  notaryContact    String?
  loanAmount       Float?
  loanApproved     Boolean           @default(false)
  conditions       Json? // Conditions suspensives
  metadata         Json?
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt

  user        users             @relation("UserTransactions", fields: [userId], references: [id], onDelete: Cascade)
  property    properties        @relation("PropertyTransactions", fields: [propertyId], references: [id], onDelete: Restrict)
  prospect    prospects?        @relation("ProspectTransactions", fields: [prospectId], references: [id], onDelete: SetNull)
  mandate     Mandate?          @relation(fields: [mandateId], references: [id], onDelete: SetNull)
  steps       TransactionStep[]
  commissions Commission[]
  invoices    Invoice[]

  @@index([userId])
  @@index([propertyId])
  @@index([prospectId])
  @@index([mandateId])
  @@index([status])
  @@index([type])
  @@index([estimatedClosing])
  @@index([reference])
  @@map("transactions")
}

model TransactionStep {
  id            String   @id @default(cuid())
  transactionId String
  stage         String // offer_received, offer_accepted, etc.
  completedAt   DateTime @default(now())
  completedBy   String?
  notes         String?  @db.Text
  documents     Json? // Array of document URLs
  metadata      Json?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  transaction Transaction @relation(fields: [transactionId], references: [id], onDelete: Cascade)

  @@index([transactionId])
  @@index([stage])
  @@map("transaction_steps")
}

// ============================================
// 🆕 FINANCE MODULE (Commissions, Factures, Paiements)
// ============================================

model Commission {
  id            String           @id @default(cuid())
  userId        String
  transactionId String
  agentId       String
  type          String           @default("agent") // agent, agency, referral
  amount        Float
  percentage    Float?
  currency      String           @default("TND")
  status        CommissionStatus @default(pending)
  dueDate       DateTime?
  paidAt        DateTime?
  notes         String?          @db.Text
  metadata      Json?
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt

  user        users       @relation("UserCommissions", fields: [userId], references: [id], onDelete: Cascade)
  transaction Transaction @relation(fields: [transactionId], references: [id], onDelete: Restrict)
  agent       users       @relation("AgentCommissions", fields: [agentId], references: [id], onDelete: Restrict)
  payments    Payment[]

  @@index([userId])
  @@index([transactionId])
  @@index([agentId])
  @@index([status])
  @@index([dueDate])
  @@map("commissions")
}

model Invoice {
  id            String        @id @default(cuid())
  userId        String
  transactionId String?
  ownerId       String?
  number        String        @unique
  clientType    ClientType
  clientName    String
  clientEmail   String?
  clientPhone   String?
  clientAddress String?       @db.Text
  amount        Float
  vat           Float         @default(0)
  totalAmount   Float
  currency      String        @default("TND")
  status        InvoiceStatus @default(draft)
  issueDate     DateTime      @default(now())
  dueDate       DateTime
  paidAt        DateTime?
  description   String?       @db.Text
  items         Json? // Line items
  notes         String?       @db.Text
  pdfUrl        String?
  metadata      Json?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  user        users        @relation("UserInvoices", fields: [userId], references: [id], onDelete: Cascade)
  transaction Transaction? @relation(fields: [transactionId], references: [id], onDelete: SetNull)
  owner       Owner?       @relation(fields: [ownerId], references: [id], onDelete: SetNull)
  payments    Payment[]

  @@index([userId])
  @@index([transactionId])
  @@index([ownerId])
  @@index([number])
  @@index([status])
  @@index([dueDate])
  @@map("invoices")
}

model Payment {
  id           String        @id @default(cuid())
  userId       String
  invoiceId    String?
  commissionId String?
  amount       Float
  currency     String        @default("TND")
  method       PaymentMethod
  reference    String?
  paidAt       DateTime      @default(now())
  notes        String?       @db.Text
  metadata     Json?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  user       users       @relation("UserPayments", fields: [userId], references: [id], onDelete: Cascade)
  invoice    Invoice?    @relation(fields: [invoiceId], references: [id], onDelete: SetNull)
  commission Commission? @relation(fields: [commissionId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([invoiceId])
  @@index([commissionId])
  @@index([paidAt])
  @@map("payments")
}

// ============================================
// AI BILLING & MULTI-TENANT API KEYS SYSTEM
// Architecture: USER → AGENCY → SUPER ADMIN
// ============================================

// ──────────────────────────────────────────
// 1. CLÉS API AU NIVEAU AGENCE (BYOK)
// ──────────────────────────────────────────
model AgencyApiKeys {
  id       String   @id @default(cuid())
  agencyId String   @unique
  agency   agencies @relation(fields: [agencyId], references: [id], onDelete: Cascade)

  // ── LLM Providers ──
  llmProvider      String? @default("anthropic") // Provider par défaut
  llmApiKey        String? // Clé LLM principale (déprécié, utiliser les spécifiques)
  anthropicApiKey  String?
  openaiApiKey     String?
  geminiApiKey     String?
  deepseekApiKey   String?
  openrouterApiKey String?

  // ── Scraping & Data Providers ──
  serpApiKey        String? // Google SERP
  firecrawlApiKey   String? // Firecrawl web scraping
  picaApiKey        String? // Pica real estate data
  jinaReaderApiKey  String? // Jina Reader (URL → Markdown)
  scrapingBeeApiKey String? // ScrapingBee
  browserlessApiKey String? // Browserless headless browser
  rapidApiKey       String? // RapidAPI (futur)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("agency_api_keys")
}

// ──────────────────────────────────────────
// 2. PRICING DES ACTIONS IA
// ──────────────────────────────────────────
model AiPricing {
  id          String  @id @default(cuid())
  actionCode  String  @unique // Ex: "AI_PROSPECTION_INTERNAL", "AI_MATCHING"
  actionName  String // Nom lisible
  description String?

  creditsCost Int // Crédits consommés par action

  // Détails techniques (optionnel)
  estimatedTokens Int? // Tokens moyens
  providerCostUsd Float? // Coût réel USD

  enabled  Boolean @default(true)
  category String? // "prospecting", "matching", "seo", "chat", "email"

  // ── Nouvelles relations Module Registry (Phase 1) ──
  moduleAiActions ModuleAiAction[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("ai_pricing")
}

// ──────────────────────────────────────────
// 3. CONSOMMATION DE CRÉDITS (Billing)
// ──────────────────────────────────────────
model AiUsage {
  id String @id @default(cuid())

  // ── Soit agence, soit user (au moins un des deux) ──
  agencyId String?
  agency   agencies? @relation(fields: [agencyId], references: [id], onDelete: Cascade)

  userId String?
  user   users?  @relation(fields: [userId], references: [id], onDelete: SetNull)

  // ── Action ──
  actionCode String
  actionName String?

  // ── Crédits ──
  creditsUsed    Int
  creditsBalance Int? // Snapshot du solde après

  // ── Métadonnées techniques ──
  provider    String? // "anthropic", "serp", etc.
  model       String?
  tokensUsed  Int?
  realCostUsd Float?

  // ── Contexte métier ──
  entityType String? // "prospect", "property", "campaign"
  entityId   String?

  metadata Json?

  createdAt DateTime @default(now())

  @@index([agencyId, createdAt])
  @@index([userId, createdAt])
  @@index([actionCode])
  @@map("ai_usage")
}

// ──────────────────────────────────────────
// 4. LOGS D'ERREURS IA
// ──────────────────────────────────────────
model AiErrorLog {
  id String @id @default(cuid())

  agencyId String?
  agency   agencies? @relation(fields: [agencyId], references: [id], onDelete: SetNull)

  userId String?
  user   users?  @relation(fields: [userId], references: [id], onDelete: SetNull)

  actionCode   String
  provider     String
  errorType    String // "api_key_invalid", "quota_exceeded", "network_error"
  errorMessage String @db.Text

  // Contexte technique
  statusCode Int?
  endpoint   String?

  // Contexte métier
  entityType String?
  entityId   String?

  metadata Json?

  createdAt DateTime @default(now())

  @@index([agencyId, createdAt])
  @@index([userId, createdAt])
  @@index([provider, errorType])
  @@map("ai_error_log")
}

// ──────────────────────────────────────────
// 5. CRÉDITS AGENCE (pool partagé)
// ──────────────────────────────────────────
model AiCredits {
  id       String   @id @default(cuid())
  agencyId String   @unique
  agency   agencies @relation(fields: [agencyId], references: [id], onDelete: Cascade)

  balance      Int  @default(0)
  consumed     Int  @default(0)
  quotaMonthly Int? // null = illimité
  quotaDaily   Int?

  // Reset automatique
  lastResetAt    DateTime?
  resetFrequency String?   @default("monthly") // "daily", "weekly", "monthly", "never"

  // Alertes
  alertThreshold Int?    @default(20) // % restants
  alertSent      Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("ai_credits")
}

// ──────────────────────────────────────────
// 6. CRÉDITS USER (users indépendants)
// ──────────────────────────────────────────
model UserAiCredits {
  id     String @id @default(cuid())
  userId String @unique
  user   users  @relation(fields: [userId], references: [id], onDelete: Cascade)

  balance      Int  @default(0)
  consumed     Int  @default(0)
  quotaMonthly Int?
  quotaDaily   Int?

  lastResetAt    DateTime?
  resetFrequency String?   @default("monthly")

  alertThreshold Int?    @default(20)
  alertSent      Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("user_ai_credits")
}

// ──────────────────────────────────────────
// 7. GLOBAL SETTINGS (Super Admin)
// ──────────────────────────────────────────
model GlobalSettings {
  id    String @id @default(cuid())
  key   String @unique
  value String @db.Text

  encrypted   Boolean @default(false)
  description String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("global_settings")
}

// ════════════════════════════════════════════════════════════
// MODULE REGISTRY - SAAS CORE OS (PHASE 1)
// Système de "Plug & Play" pour modules métier
// Architecture: Core OS agnostique + Modules Business enchufables
// ════════════════════════════════════════════════════════════

// ──────────────────────────────────────────────────────────────
// ENUMS
// ──────────────────────────────────────────────────────────────
enum ModuleStatus {
  ACTIVE
  INACTIVE
  DEPRECATED
}

enum ModuleCategory {
  BUSINESS // Modules métier (Immo, Voyage, Casting, RH)
  INTELLIGENCE // Modules IA (Matching, Scoring, RAG)
  INTEGRATION // Intégrations externes (WordPress, Stripe, n8n)
  COMMUNICATION // Email, SMS, Notifications
  MARKETING // SEO, Ads, Analytics
}

// ──────────────────────────────────────────────────────────────
// 1. BUSINESS MODULES (Registre des modules métier)
// ──────────────────────────────────────────────────────────────
model BusinessModule {
  id          String         @id @default(cuid())
  code        String         @unique // "real-estate", "travel", "casting"
  name        String // "Immobilier", "Voyage", "Casting"
  description String?        @db.Text
  version     String         @default("1.0.0")
  status      ModuleStatus   @default(ACTIVE)
  category    ModuleCategory @default(BUSINESS)

  // Manifest JSON (déclaration des besoins du module)
  manifest Json // { menus, permissions, schemas, aiActions }

  // Pricing (coût d'activation du module)
  basePrice       Float? // Prix de base mensuel (EUR)
  creditsIncluded Int? // Crédits IA inclus par mois

  // Relations
  subscriptions ModuleAgencySubscription[]
  menuItems     DynamicMenuItem[]
  aiActions     ModuleAiAction[]
  schemas       DynamicSchema[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([code])
  @@index([status])
  @@map("business_modules")
}

// ──────────────────────────────────────────────────────────────
// 2. SOUSCRIPTIONS AGENCES (qui a activé quoi)
// ──────────────────────────────────────────────────────────────
model ModuleAgencySubscription {
  id String @id @default(cuid())

  agencyId String
  agency   agencies @relation(fields: [agencyId], references: [id], onDelete: Cascade)

  moduleId String
  module   BusinessModule @relation(fields: [moduleId], references: [id], onDelete: Cascade)

  // Activation
  isActive    Boolean   @default(true)
  activatedAt DateTime  @default(now())
  expiresAt   DateTime?

  // Configuration spécifique agence (override manifest)
  config Json? // Configuration custom du module

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([agencyId, moduleId])
  @@index([agencyId])
  @@index([moduleId])
  @@map("module_agency_subscriptions")
}

// ──────────────────────────────────────────────────────────────
// 3. MENU ITEMS DYNAMIQUES (générés depuis le manifest)
// ──────────────────────────────────────────────────────────────
model DynamicMenuItem {
  id String @id @default(cuid())

  moduleId String
  module   BusinessModule @relation(fields: [moduleId], references: [id], onDelete: Cascade)

  // Menu structure
  label    String // "Biens", "Prospects", "Voyages"
  icon     String? // "Home", "Users", "Plane"
  path     String // "/properties", "/prospects", "/trips"
  parentId String? // Pour sous-menus hiérarchiques
  order    Int     @default(0)

  // Permissions
  requiredRole UserRole? // Minimum role required (null = tous)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([moduleId, path])
  @@index([moduleId])
  @@map("dynamic_menu_items")
}

// ──────────────────────────────────────────────────────────────
// 4. AI ACTIONS PAR MODULE (actions IA disponibles)
// ──────────────────────────────────────────────────────────────
model ModuleAiAction {
  id String @id @default(cuid())

  moduleId String
  module   BusinessModule @relation(fields: [moduleId], references: [id], onDelete: Cascade)

  actionCode  String  @unique // "real_estate_matching", "travel_scoring"
  actionName  String // "Matching Bien-Prospect", "Scoring Voyage"
  description String? @db.Text

  // Lien avec le pricing existant
  pricingId String?
  pricing   AiPricing? @relation(fields: [pricingId], references: [id])

  // Configuration IA (prompts & modèles)
  systemPrompt  String? @db.Text
  userPromptTpl String? @db.Text
  provider      String? // "anthropic", "openai", "deepseek"
  model         String? // "claude-3-5-sonnet", "gpt-4o"

  enabled Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([moduleId])
  @@index([actionCode])
  @@map("module_ai_actions")
}

// ──────────────────────────────────────────────────────────────
// 5. SCHEMAS MÉTIER DYNAMIQUES (optionnel, avancé)
// ──────────────────────────────────────────────────────────────
model DynamicSchema {
  id String @id @default(cuid())

  moduleId String
  module   BusinessModule @relation(fields: [moduleId], references: [id], onDelete: Cascade)

  tableName String // "properties", "trips", "missions"
  schema    Json // JSON Schema du modèle métier

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([moduleId, tableName])
  @@index([moduleId])
  @@map("dynamic_schemas")
}

// ═══════════════════════════════════════════════════════════════════
// PROVIDER REGISTRY - UNIFIED PROVIDERS MANAGEMENT (Phase 1)
// ═══════════════════════════════════════════════════════════════════

// Type de provider (catégorie principale)
enum ProviderType {
  scraping // Providers de scraping (Cheerio, Puppeteer, Firecrawl, Pica, SerpAPI)
  llm // Providers LLM (Anthropic, OpenAI, Gemini, etc.)
  storage // Providers de stockage (S3, Cloudinary, etc.)
  email // Providers d'email (SendGrid, Mailgun, etc.)
  payment // Providers de paiement (Stripe, PayPal, etc.)
  communication // Providers de communication (Twilio, WhatsApp, etc.)
  integration // Providers d'intégration (Zapier, Make, etc.)
}

// Catégorie de provider (sous-type)
enum ProviderCategory {
  internal // Provider interne (ex: Cheerio, Puppeteer)
  external_api // Provider API externe (ex: Firecrawl, OpenAI)
  cloud_service // Provider cloud (ex: AWS, GCP)
  saas // Provider SaaS (ex: SendGrid, Stripe)
}

// Statut du provider
enum ProviderStatus {
  active // Actif et disponible
  inactive // Désactivé temporairement
  error // En erreur (clé invalide, quota dépassé, etc.)
  testing // En phase de test
}

// ──────────────────────────────────────────────────────────────
// PROVIDER CONFIG - Configuration unifiée de tous les providers
// ──────────────────────────────────────────────────────────────
model ProviderConfig {
  id String @id @default(cuid())

  // Identification
  type        ProviderType // Type de provider (scraping, llm, storage, etc.)
  category    ProviderCategory // Catégorie (internal, external_api, etc.)
  provider    String // Nom du provider (ex: 'firecrawl', 'anthropic', 'cheerio')
  name        String // Nom affiché (ex: 'Firecrawl API', 'Claude 3.5 Sonnet')
  description String?          @db.Text

  // Multi-tenant
  userId   String? // User spécifique (null = provider global/système)
  agencyId String? // Agency spécifique (pour facturation agence)

  // Authentification & Configuration
  apiKey    String? // Clé API (cryptée)
  apiSecret String? // Secret API (crypté)
  endpoint  String? // Endpoint personnalisé
  config    Json? // Configuration additionnelle (modèle, options, etc.)

  // État & Priorité
  status   ProviderStatus @default(active)
  isActive Boolean        @default(true)
  priority Int            @default(0) // 0 = plus haute priorité

  // Budget & Limites
  monthlyBudget Float? // Budget mensuel (en $)
  dailyBudget   Float? // Budget journalier (en $)
  rateLimit     Int? // Limite de requêtes par minute
  maxConcurrent Int? // Nombre max de requêtes simultanées

  // Tracking Usage
  monthlyUsage Float     @default(0) // Coût ce mois (en $)
  dailyUsage   Float     @default(0) // Coût aujourd'hui (en $)
  totalCalls   Int       @default(0) // Total d'appels API
  successCalls Int       @default(0) // Appels réussis
  failedCalls  Int       @default(0) // Appels échoués
  lastUsedAt   DateTime? // Dernière utilisation

  // Métriques Performance
  avgLatency  Float @default(0) // Latence moyenne (ms)
  successRate Float @default(100) // Taux de succès (0-100%)

  // Metadata
  metadata Json? // Données additionnelles
  tags     String[] // Tags pour filtrage

  // Timestamps
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
  lastHealthCheckAt DateTime? // Dernier test de santé

  // Relations
  user      users?             @relation("UserProviders", fields: [userId], references: [id], onDelete: Cascade)
  agency    agencies?          @relation("AgencyProviders", fields: [agencyId], references: [id], onDelete: Cascade)
  usageLogs ProviderUsageLog[] @relation("ProviderUsageLogs")
  metrics   ProviderMetrics[]  @relation("ProviderMetrics")

  @@unique([userId, type, provider])
  @@unique([agencyId, type, provider])
  @@index([userId])
  @@index([agencyId])
  @@index([type])
  @@index([provider])
  @@index([status])
  @@index([isActive])
  @@index([userId, type])
  @@index([agencyId, type])
  @@map("provider_configs")
}

// ──────────────────────────────────────────────────────────────
// PROVIDER USAGE LOG - Logs d'utilisation détaillés
// ──────────────────────────────────────────────────────────────
model ProviderUsageLog {
  id String @id @default(cuid())

  // Référence provider
  providerConfigId String
  providerConfig   ProviderConfig @relation("ProviderUsageLogs", fields: [providerConfigId], references: [id], onDelete: Cascade)

  // Context
  userId        String?
  agencyId      String?
  operationType String // 'scraping', 'llm_generation', 'email_send', etc.
  operationCode String? // Code spécifique (ex: 'prospecting_qualify', 'seo_generate')

  // Métadonnées de l'appel
  requestData  Json? // Données de la requête
  responseData Json? // Données de la réponse

  // Métriques
  tokensInput  Int? // Tokens d'entrée (LLM)
  tokensOutput Int? // Tokens de sortie (LLM)
  latencyMs    Int? // Latence en ms
  cost         Float? // Coût de l'opération

  // Statut
  success      Boolean @default(true)
  errorMessage String? @db.Text
  errorCode    String?

  // Timestamps
  createdAt DateTime @default(now())

  @@index([providerConfigId])
  @@index([userId])
  @@index([agencyId])
  @@index([operationType])
  @@index([createdAt])
  @@index([success])
  @@map("provider_usage_logs")
}

// ──────────────────────────────────────────────────────────────
// PROVIDER METRICS - Métriques agrégées par provider
// ──────────────────────────────────────────────────────────────
model ProviderMetrics {
  id String @id @default(cuid())

  // Référence provider
  providerConfigId String
  providerConfig   ProviderConfig @relation("ProviderMetrics", fields: [providerConfigId], references: [id], onDelete: Cascade)

  // Période
  date          DateTime @db.Date // Date de la métrique (agrégation journalière)
  operationType String? // Type d'opération spécifique (optionnel)

  // Métriques agrégées
  totalCalls   Int    @default(0)
  successCalls Int    @default(0)
  failedCalls  Int    @default(0)
  avgLatency   Float  @default(0)
  minLatency   Float?
  maxLatency   Float?
  totalCost    Float  @default(0)
  totalTokens  Int? // Pour LLM

  // Timestamps
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([providerConfigId, date, operationType])
  @@index([providerConfigId])
  @@index([date])
  @@index([operationType])
  @@map("provider_metrics")
}

// ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
// WHATSAPP BOT - Communication via WhatsApp Business API
// ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

// ──────────────────────────────────────────────────────────────
// WHATSAPP CONFIG - Configuration WhatsApp par utilisateur/agence
// ──────────────────────────────────────────────────────────────
model WhatsAppConfig {
  id String @id @default(cuid())

  // Owner
  userId   String? @unique
  agencyId String? @unique

  // Meta Cloud API
  phoneNumberId     String? // Meta phone number ID
  businessAccountId String? // Meta business account ID
  accessToken       String? @db.Text // Meta access token

  // Twilio (alternative)
  twilioAccountSid  String?
  twilioAuthToken   String? @db.Text
  twilioPhoneNumber String?

  // Configuration
  provider WhatsAppProvider @default(meta)
  isActive Boolean          @default(false)

  // Webhooks
  webhookUrl    String?
  webhookSecret String?

  // Auto-reply settings
  autoReplyEnabled   Boolean @default(false)
  businessHoursOnly  Boolean @default(false)
  businessHoursStart String? // Format: "09:00"
  businessHoursEnd   String? // Format: "18:00"

  // Timestamps
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  user          users?                 @relation("UserWhatsAppConfig", fields: [userId], references: [id], onDelete: Cascade)
  agency        agencies?              @relation("AgencyWhatsAppConfig", fields: [agencyId], references: [id], onDelete: Cascade)
  conversations WhatsAppConversation[] @relation("ConfigConversations")
  templates     WhatsAppTemplate[]     @relation("ConfigTemplates")
  contacts      WhatsAppContact[]      @relation("ConfigContacts")
  campaigns     WhatsAppCampaign[]     @relation("ConfigCampaigns")

  @@map("whatsapp_configs")
}

// ──────────────────────────────────────────────────────────────
// WHATSAPP CONVERSATION - Conversations WhatsApp
// ──────────────────────────────────────────────────────────────
model WhatsAppConversation {
  id String @id @default(cuid())

  // Configuration
  configId String
  config   WhatsAppConfig @relation("ConfigConversations", fields: [configId], references: [id], onDelete: Cascade)

  // Contact info
  phoneNumber String // E.164 format: +33612345678
  contactName String?

  // CRM links
  leadId     String?
  prospectId String?
  userId     String?
  agencyId   String?

  // Conversation metadata
  status     ConversationStatus @default(open)
  assignedTo String? // User ID
  tags       String[] // ["hot_lead", "viewing_scheduled"]

  // Counters
  messageCount Int @default(0)
  unreadCount  Int @default(0)

  // Timestamps
  lastMessageAt DateTime @default(now())
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  // Relations
  lead     prospecting_leads? @relation("LeadWhatsAppConversations", fields: [leadId], references: [id], onDelete: SetNull)
  user     users?             @relation("UserWhatsAppConversations", fields: [userId], references: [id], onDelete: Cascade)
  agency   agencies?          @relation("AgencyWhatsAppConversations", fields: [agencyId], references: [id], onDelete: Cascade)
  messages WhatsAppMessage[]  @relation("ConversationMessages")

  @@index([configId])
  @@index([phoneNumber])
  @@index([leadId])
  @@index([status])
  @@index([lastMessageAt])
  @@map("whatsapp_conversations")
}

// ──────────────────────────────────────────────────────────────
// WHATSAPP MESSAGE - Messages WhatsApp
// ──────────────────────────────────────────────────────────────
model WhatsAppMessage {
  id String @id @default(cuid())

  // Conversation
  conversationId String
  conversation   WhatsAppConversation @relation("ConversationMessages", fields: [conversationId], references: [id], onDelete: Cascade)

  // Message info
  messageId String           @unique // WhatsApp message ID
  direction MessageDirection // inbound | outbound

  // Content
  type    MessageType // text | image | document | template | location
  content String      @db.Text // Text content or media URL
  caption String?     @db.Text // For media messages

  // Media
  mediaUrl  String?
  mimeType  String?
  mediaSize Int? // Size in bytes

  // Template (for outbound)
  templateName   String?
  templateParams Json?

  // Status
  status MessageStatus @default(sent)

  // Metadata
  sentBy      String? // User ID (if outbound)
  timestamp   DateTime  @default(now())
  deliveredAt DateTime?
  readAt      DateTime?

  // Error tracking
  errorCode    String?
  errorMessage String? @db.Text

  // Timestamps
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  sender users? @relation("UserWhatsAppMessages", fields: [sentBy], references: [id], onDelete: SetNull)

  @@index([conversationId])
  @@index([messageId])
  @@index([direction])
  @@index([timestamp])
  @@map("whatsapp_messages")
}

// ──────────────────────────────────────────────────────────────
// WHATSAPP TEMPLATE - Templates de messages WhatsApp
// ──────────────────────────────────────────────────────────────
model WhatsAppTemplate {
  id String @id @default(cuid())

  // Configuration
  configId String
  config   WhatsAppConfig @relation("ConfigTemplates", fields: [configId], references: [id], onDelete: Cascade)

  // Template info
  name     String
  language String           @default("fr")
  category TemplateCategory

  // Template content
  header  String? @db.Text
  body    String  @db.Text
  footer  String? @db.Text
  buttons Json? // Array of button objects

  // Variables
  variables String[] // ["{{1}}", "{{2}}"]

  // Status
  status         TemplateStatus @default(pending)
  approvedAt     DateTime?
  rejectedReason String?        @db.Text

  // Stats
  sentCount      Int @default(0)
  deliveredCount Int @default(0)
  readCount      Int @default(0)
  failedCount    Int @default(0)

  // Timestamps
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  campaigns WhatsAppCampaign[] @relation("TemplateCampaigns")

  @@unique([configId, name])
  @@index([configId])
  @@index([status])
  @@index([category])
  @@map("whatsapp_templates")
}

// ──────────────────────────────────────────────────────────────
// WHATSAPP CONTACT - WhatsApp Contacts Management
// ──────────────────────────────────────────────────────────────
model WhatsAppContact {
  id String @id @default(cuid())

  // Configuration
  configId String
  config   WhatsAppConfig @relation("ConfigContacts", fields: [configId], references: [id], onDelete: Cascade)

  // Contact info
  phoneNumber    String // E.164 format: +33612345678
  name           String?
  email          String?
  profilePicture String? @db.Text

  // Organization
  tags         String[] @default([])
  groups       String[] @default([])
  notes        String?  @db.Text
  customFields Json? // Custom fields as JSON object

  // Status
  isBlocked Boolean @default(false)

  // Stats (cached for performance)
  totalMessages       Int       @default(0)
  sentMessages        Int       @default(0)
  receivedMessages    Int       @default(0)
  totalConversations  Int       @default(0)
  activeConversations Int       @default(0)
  avgResponseTime     Int       @default(0) // in minutes
  lastInteractionAt   DateTime?

  // Timestamps
  lastMessageAt DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@unique([configId, phoneNumber])
  @@index([configId])
  @@index([phoneNumber])
  @@index([isBlocked])
  @@index([tags])
  @@index([groups])
  @@map("whatsapp_contacts")
}

// ──────────────────────────────────────────────────────────────
// WHATSAPP CAMPAIGN - WhatsApp Campaign Management
// ──────────────────────────────────────────────────────────────
model WhatsAppCampaign {
  id String @id @default(cuid())

  // Configuration
  configId String
  config   WhatsAppConfig @relation("ConfigCampaigns", fields: [configId], references: [id], onDelete: Cascade)

  // Campaign info
  name        String
  description String?        @db.Text
  type        CampaignType
  status      CampaignStatus @default(draft)

  // Template
  templateId   String
  template     WhatsAppTemplate @relation("TemplateCampaigns", fields: [templateId], references: [id], onDelete: Restrict)
  templateName String // Cached for display

  // Scheduling
  scheduledAt DateTime?
  startedAt   DateTime?
  completedAt DateTime?
  pausedAt    DateTime?
  cancelledAt DateTime?

  // Stats
  totalRecipients Int @default(0)
  sentCount       Int @default(0)
  deliveredCount  Int @default(0)
  readCount       Int @default(0)
  failedCount     Int @default(0)
  pendingCount    Int @default(0)

  // Metadata
  createdBy String // User ID
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  recipients WhatsAppCampaignRecipient[] @relation("CampaignRecipients")

  @@index([configId])
  @@index([status])
  @@index([type])
  @@index([templateId])
  @@index([scheduledAt])
  @@map("whatsapp_campaigns")
}

model WhatsAppCampaignRecipient {
  id String @id @default(cuid())

  // Campaign
  campaignId String
  campaign   WhatsAppCampaign @relation("CampaignRecipients", fields: [campaignId], references: [id], onDelete: Cascade)

  // Recipient info
  contactId   String? // Optional link to WhatsAppContact
  phoneNumber String // E.164 format
  name        String?
  variables   Json? // Template variables as JSON object

  // Status
  status       RecipientStatus @default(pending)
  sentAt       DateTime?
  deliveredAt  DateTime?
  readAt       DateTime?
  failedAt     DateTime?
  errorMessage String?         @db.Text

  // WhatsApp message ID (for tracking)
  messageId String?

  // Timestamps
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([campaignId])
  @@index([status])
  @@index([phoneNumber])
  @@map("whatsapp_campaign_recipients")
}

// ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
// MARKETING TRACKING - Advanced Features (Heatmaps, A/B Testing)
// ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

// ──────────────────────────────────────────────────────────────
// HEATMAP EVENTS - Track clicks, mouse movements, and scrolls
// ──────────────────────────────────────────────────────────────
model HeatmapEvent {
  id           String   @id @default(cuid())
  userId       String   // Owner of the vitrine
  pageUrl      String   // Full URL of the page
  x            Int      // X coordinate
  y            Int      // Y coordinate
  type         String   // 'click' | 'move' | 'scroll'
  sessionId    String   // User session identifier
  deviceType   String   @default("desktop") // 'desktop' | 'mobile' | 'tablet'
  screenWidth  Int      @default(1920)
  screenHeight Int      @default(1080)
  element      String?  // CSS selector of clicked element
  userAgent    String?  @db.Text
  timestamp    DateTime @default(now())

  @@index([userId, pageUrl, type])
  @@index([sessionId])
  @@index([pageUrl])
  @@index([timestamp])
  @@map("heatmap_events")
}

// ──────────────────────────────────────────────────────────────
// A/B TESTING - Test different tracking pixel configurations
// ──────────────────────────────────────────────────────────────
model TrackingABTest {
  id             String   @id @default(cuid())
  userId         String   // Test owner
  name           String   // Test name
  description    String?  @db.Text
  variantAConfig Json     // Tracking config for variant A
  variantBConfig Json     // Tracking config for variant B
  trafficSplit   Int      @default(50) // 0-100, percentage for variant A
  startDate      DateTime
  endDate        DateTime
  status         String   @default("running") // 'running' | 'stopped' | 'completed'
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  assignments TrackingABTestAssignment[]
  results     TrackingABTestResult[]

  @@index([userId])
  @@index([status])
  @@index([startDate, endDate])
  @@map("tracking_ab_tests")
}

// Variant assignment per session (deterministic)
model TrackingABTestAssignment {
  testId    String
  test      TrackingABTest @relation(fields: [testId], references: [id], onDelete: Cascade)
  sessionId String
  variant   String         // 'A' | 'B'
  createdAt DateTime       @default(now())

  @@id([testId, sessionId])
  @@index([sessionId])
  @@map("tracking_ab_test_assignments")
}

// Results per variant
model TrackingABTestResult {
  id        String         @id @default(cuid())
  testId    String
  test      TrackingABTest @relation(fields: [testId], references: [id], onDelete: Cascade)
  sessionId String
  variant   String // 'A' | 'B'
  eventName String // Event that was tracked
  value     Float? // Optional value (for revenue tracking)
  timestamp DateTime @default(now())

  @@index([testId, variant])
  @@index([sessionId])
  @@index([eventName])
  @@map("tracking_ab_test_results")
}
