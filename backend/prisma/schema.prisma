generator client {
  provider = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================
// ENUMS - Typed values for database constraints
// ============================================

enum PropertyStatus {
  available
  reserved
  sold
  rented
  pending
}

enum PropertyType {
  apartment
  house
  villa
  studio
  land
  commercial
  office
  appartement
  maison
  terrain
}

enum PropertyCategory {
  sale
  rent
}

enum PropertyPriority {
  low
  medium
  high
  urgent
}

enum LeadStatus {
  new
  contacted
  qualified
  converted
  rejected
}

enum LeadType {
  requete
  mandat
  inconnu
}

enum ValidationStatus {
  pending
  valid
  suspicious
  spam
}

enum MatchStatus {
  pending
  notified
  contacted
  converted
  ignored
}

enum Intention {
  acheter
  louer
  vendre
  investir
  inconnu
}

enum Urgency {
  basse
  moyenne
  haute
  inconnu
}

enum CampaignStatus {
  draft
  active
  paused
  completed
}

enum MandateType {
  simple
  exclusive
  semi_exclusive
}

enum MandateCategory {
  sale
  rental
}

enum MandateStatus {
  active
  expired
  cancelled
  completed
}

enum TransactionType {
  sale
  rental
}

enum TransactionStatus {
  offer_received
  offer_accepted
  promise_signed
  compromis_signed
  final_deed_signed
  cancelled
}

enum CommissionStatus {
  pending
  partially_paid
  paid
  cancelled
}

enum InvoiceStatus {
  draft
  sent
  paid
  partially_paid
  overdue
  cancelled
}

enum PaymentMethod {
  cash
  check
  bank_transfer
  credit_card
  other
}

enum ClientType {
  buyer
  seller
  tenant
  landlord
}

// ============================================
// MODELS
// ============================================

model ProspectingSource {
  id          String    @id @default(cuid())
  name        String
  url         String?
  type        String
  config      Json?
  lastScraped DateTime?
  isActive    Boolean   @default(true)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model agencies {
  id         String       @id @default(cuid())
  name       String
  address    String?
  phone      String?
  email      String?
  createdAt  DateTime     @default(now())
  updatedAt  DateTime     @updatedAt
  properties properties[]
  prospects  prospects[]
  users      users[]

  // ── Nouvelles relations AI Billing ──
  apiKeys      AgencyApiKeys?
  aiCredits    AiCredits?
  aiUsages     AiUsage[]
  aiErrorLogs  AiErrorLog[]

  // ── Nouvelles relations Module Registry (Phase 1) ──
  moduleSubscriptions ModuleAgencySubscription[]
}

model appointments {
  id             String      @id @default(cuid())
  userId         String
  prospectId     String?
  propertyId     String?
  title          String
  description    String?
  startTime      DateTime
  endTime        DateTime
  location       String?
  type           String      @default("visit")
  status         String      @default("scheduled")
  prospectType   String?
  subType        String?
  searchCriteria Json?
  mandatInfo     Json?
  profiling      Json?
  timeline       String?
  budget         Json?
  priority       String      @default("medium")
  isAllDay       Boolean     @default(false)
  reminder       Boolean     @default(true)
  reminderSent   Boolean     @default(false)
  reminderTime   Int?        @default(60)
  attendees      Json?
  notes          String?
  outcome        String?
  rating         Int?
  googleEventId  String?
  iCalUid        String?
  recurrence     Json?
  color          String?     @default("#3B82F6")
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt
  properties     properties? @relation(fields: [propertyId], references: [id])
  prospects      prospects?  @relation(fields: [prospectId], references: [id])
  users          users       @relation(fields: [userId], references: [id], onDelete: Cascade)
  tasks          tasks[]     @relation("AppointmentTasks")

  @@index([userId])
  @@index([prospectId])
  @@index([propertyId])
  @@index([startTime])
  @@index([status])
  @@index([type])
}

model campaigns {
  id             String    @id @default(cuid())
  userId         String
  name           String
  description    String?
  type           String
  status         String    @default("draft")
  prospectType   String?
  subType        String?
  searchCriteria Json?
  mandatInfo     Json?
  profiling      Json?
  timeline       String?
  budget         Json?
  content        Json
  recipients     Json
  scheduledAt    DateTime?
  sentAt         DateTime?
  stats          Json?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  users          users     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model matches {
  id             String     @id @default(cuid())
  propertyId     String
  prospectId     String
  score          Float
  reasons        Json?
  status         String     @default("pending")
  prospectType   String?
  subType        String?
  searchCriteria Json?
  mandatInfo     Json?
  profiling      Json?
  timeline       String?
  budget         Json?
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt
  properties     properties @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  prospects      prospects  @relation(fields: [prospectId], references: [id], onDelete: Cascade)

  @@unique([propertyId, prospectId])
}

model properties {
  id                  String                      @id @default(cuid())
  userId              String
  agencyId            String?
  reference           String?
  title               String
  description         String?
  type                String                      // PropertyType as string for flexibility
  category            PropertyCategory            @default(sale)
  price               Float
  currency            String                      @default("TND")
  address             String?
  city                String?
  delegation          String?
  zipCode             String?
  latitude            Float?
  longitude           Float?
  bedrooms            Int?
  bathrooms           Int?
  area                Float?
  images              String[]                    // Array of image URLs
  features            String[]                    // Array of feature strings
  status              PropertyStatus              @default(available)
  viewsCount          Int                         @default(0)
  // DEPRECATED: These fields couple properties to prospecting domain
  // Should be moved to prospecting_matches or a separate junction table
  // TODO: Migrate data and remove in future version
  prospectType        String?                     // @deprecated - use prospecting_leads.leadType
  subType             String?                     // @deprecated
  searchCriteria      Json?                       // @deprecated - use prospecting_leads criteria
  mandatInfo          Json?                       // @deprecated - use prospecting_leads.metadata
  profiling           Json?                       // @deprecated
  timeline            String?                     // @deprecated - use prospecting_leads.urgency
  budget              Json?                       // @deprecated - use prospecting_leads.budget*
  wpSyncId            String?
  wpSyncedAt          DateTime?
  wordpressId         String?
  deletedAt           DateTime?                   // Soft delete timestamp
  createdAt           DateTime                    @default(now())
  updatedAt           DateTime                    @updatedAt

  // Relations
  history             PropertyHistory[]
  propertySeo         PropertySeo?
  publishedProperty   PublishedProperty[]
  vitrineAnalytics    VitrineAnalytics[]
  appointments        appointments[]
  communications      communications[]
  documents           documents[]
  matches             matches[]
  agencies            agencies?                   @relation(fields: [agencyId], references: [id])
  users               users                       @relation(fields: [userId], references: [id], onDelete: Cascade)
  prospectShown              prospect_properties_shown[]     @relation("PropertyProspectShown")
  prospecting_matches        prospecting_matches[]           @relation("PropertyMatches")
  matchedLeads               prospecting_lead_properties[]   @relation("PropertyLeadMatches")
  tasks                      tasks[]                         @relation("PropertyTasks")

  // Priority & Organization
  priority            PropertyPriority            @default(medium)
  tags                String[]                    // Array of tag strings
  assignedTo          String?
  isFeatured          Boolean                     @default(false)
  notes               String?
  lastContactAt       DateTime?
  assignedUser        users?                      @relation("AssignedProperties", fields: [assignedTo], references: [id])

  // Owner/Vendor (deprecated - use ownerNew)
  ownerId             String?
  owner               prospects?                  @relation("PropertyOwner", fields: [ownerId], references: [id])

  // New Owner relation
  ownerNewId          String?
  ownerNew            Owner?                      @relation("OwnerProperties", fields: [ownerNewId], references: [id])

  // Business relations
  mandates            Mandate[]                   @relation("PropertyMandates")
  transactions        Transaction[]               @relation("PropertyTransactions")

  // Financials
  netPrice            Float?
  fees                Float?
  feesPercentage      Float?

  @@index([priority])
  @@index([isFeatured])
  @@index([assignedTo])
  @@index([ownerId])
  @@index([ownerNewId])
  // Indexes for matching performance
  @@index([price])
  @@index([city])
  @@index([type])
  @@index([status])
  @@index([deletedAt])
  @@index([userId, status, price])  // Composite for matching queries
}

model prospects {
  id                   String                      @id @default(cuid())
  userId               String
  agencyId             String?
  firstName            String?
  lastName             String?
  email                String?
  phone                String?
  type                 String
  currency             String                      @default("TND")
  preferences          Json?
  source               String?
  status               String                      @default("active")
  score                Int                         @default(0)
  prospectType         String?
  subType              String?
  searchCriteria       Json?
  mandatInfo           Json?
  profiling            Json?
  timeline             String?
  budget               Json?
  notes                String?
  deletedAt            DateTime?
  createdAt            DateTime                    @default(now())
  updatedAt            DateTime                    @updatedAt
  appointments         appointments[]
  communications       communications[]
  contact_validations  contact_validations[]       @relation("ProspectValidations")
  documents            documents[]
  matches              matches[]
  interactions         prospect_interactions[]     @relation("ProspectInteractions")
  preferences_details  prospect_preferences[]      @relation("ProspectPreferences")
  propertiesShown      prospect_properties_shown[] @relation("ProspectPropertiesShown")
  timelineStages       prospect_timeline[]         @relation("ProspectTimeline")
  converted_from_leads prospecting_leads[]         @relation("ConvertedProspect")
  prospecting_matches  prospecting_matches[]       @relation("ProspectMatches")
  agencies             agencies?                   @relation(fields: [agencyId], references: [id])
  users                users                       @relation(fields: [userId], references: [id], onDelete: Cascade)
  tasks                tasks[]                     @relation("ProspectTasks")
  ownedProperties      properties[]                @relation("PropertyOwner")
  transactions         Transaction[]               @relation("ProspectTransactions")
}

model user_integrations {
  id        String   @id @default(cuid())
  userId    String
  type      String
  apiKey    String
  config    Json?
  data      Json?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  users     users    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, type])
}

// ════════════════════════════════════════════════════════════
// USER ROLES ENUM - SAAS CORE OS
// ════════════════════════════════════════════════════════════
enum UserRole {
  USER          // Utilisateur simple (ex: freelance, client final)
  AGENT         // Agent métier (immo, voyage, recruteur)
  ADMIN         // Admin agence
  SUPER_ADMIN   // Admin plateforme
}

model users {
  id                       String                    @id @default(cuid())
  email                    String                    @unique
  password                 String
  firstName                String?
  lastName                 String?
  role                     UserRole                  @default(AGENT)
  agencyId                 String?
  createdAt                DateTime                  @default(now())
  updatedAt                DateTime                  @updatedAt
  aiSuggestions            AiSuggestion[]
  detectedAnomalies        DetectedAnomaly[]
  llmConfig                LlmConfig?
  mlConfig                 MlConfig?
  pages                    Page[]
  publishedProperties      PublishedProperty[]
  seoBlogPosts             SeoBlogPost[]
  seoConfig                SeoConfig?
  trackingConfigs          TrackingConfig[]
  trackingEvents           TrackingEvent[]
  vitrineAnalytics         VitrineAnalytics[]
  vitrineConfig            VitrineConfig?
  ai_generations           ai_generations[]          @relation("UserAiGenerations")
  ai_settings              ai_settings?
  ai_usage_metrics         ai_usage_metrics[]        @relation("UserAiUsageMetrics")
  analytics_events         analytics_events[]        @relation("UserAnalyticsEvents")
  appointments             appointments[]
  campaigns                campaigns[]
  communication_templates  communication_templates[] @relation("UserCommunicationTemplates")
  communications           communications[]          @relation("UserCommunications")
  contact_validations      contact_validations[]     @relation("UserContactValidations")
  conversion_events        conversion_events[]       @relation("UserConversionEvents")
  document_templates       document_templates[]      @relation("UserDocumentTemplates")
  documents                documents[]               @relation("UserDocuments")
  ocr_results              ocr_results[]             @relation("UserOcrResults")
  properties               properties[]
  prospect_interactions    prospect_interactions[]   @relation("UserProspectInteractions")
  prospecting_campaigns    prospecting_campaigns[]   @relation("UserProspectingCampaigns")
  prospecting_leads        prospecting_leads[]       @relation("UserProspectingLeads")
  prospects                prospects[]
  prospectHistory          ProspectHistory[]         @relation("UserProspectHistory")
  settings                 settings[]                @relation("UserSettings")
  tasks                    tasks[]                   @relation("UserTasks")
  user_integrations        user_integrations[]
  aiOrchestrations         AiOrchestration[]
  toolCallLogs             ToolCallLog[]
  agencies                 agencies?                 @relation(fields: [agencyId], references: [id])
  assignedProperties       properties[]              @relation("AssignedProperties")
  notifications            Notification[]            @relation("UserNotifications")
  notificationPreferences  NotificationPreference?   @relation("UserNotificationPreferences")
  userIntegrations         UserIntegration[]         @relation("UserIntegrations")
  activities               Activity[]                @relation("UserActivities")
  owners                   Owner[]                   @relation("UserOwners")
  mandates                 Mandate[]                 @relation("UserMandates")
  transactions             Transaction[]             @relation("UserTransactions")
  commissions              Commission[]              @relation("UserCommissions")
  agentCommissions         Commission[]              @relation("AgentCommissions")
  invoices                 Invoice[]                 @relation("UserInvoices")
  payments                 Payment[]                 @relation("UserPayments")
  wordpressUrl             String?
  wordpressUsername        String?
  wordpressPassword        String?

  // ── Nouvelles relations AI Billing ──
  aiUsages                 AiUsage[]
  aiErrorLogs              AiErrorLog[]
  userAiCredits            UserAiCredits?
}

model communications {
  id             String                   @id @default(cuid())
  userId         String
  type           String
  to             String
  from           String?
  subject        String?
  body           String
  status         String                   @default("sent")
  prospectType   String?
  subType        String?
  searchCriteria Json?
  mandatInfo     Json?
  profiling      Json?
  timeline       String?
  budget         Json?
  sentAt         DateTime                 @default(now())
  deliveredAt    DateTime?
  openedAt       DateTime?
  clickedAt      DateTime?
  failedReason   String?
  prospectId     String?
  propertyId     String?
  templateId     String?
  metadata       Json?
  createdAt      DateTime                 @default(now())
  updatedAt      DateTime                 @updatedAt
  properties     properties?              @relation(fields: [propertyId], references: [id])
  prospects      prospects?               @relation(fields: [prospectId], references: [id])
  template       communication_templates? @relation(fields: [templateId], references: [id])
  users          users                    @relation("UserCommunications", fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([prospectId])
  @@index([type])
  @@index([status])
}

model communication_templates {
  id             String           @id @default(cuid())
  userId         String
  name           String
  type           String
  subject        String?
  content        String
  variables      Json
  isActive       Boolean          @default(true)
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt
  users          users            @relation("UserCommunicationTemplates", fields: [userId], references: [id], onDelete: Cascade)
  communications communications[]

  @@index([userId])
  @@index([type])
}

model document_categories {
  id          String                @id @default(cuid())
  name        String
  description String?
  color       String?
  icon        String?
  parentId    String?
  createdAt   DateTime              @default(now())
  updatedAt   DateTime              @updatedAt
  parent      document_categories?  @relation("CategoryHierarchy", fields: [parentId], references: [id])
  children    document_categories[] @relation("CategoryHierarchy")
  documents   documents[]

  @@index([parentId])
}

model documents {
  id             String               @id @default(cuid())
  userId         String
  categoryId     String?
  name           String
  originalName   String
  description    String?
  fileUrl        String
  filePath       String
  mimeType       String
  fileSize       Int
  extension      String
  prospectId     String?
  propertyId     String?
  relatedType    String?
  relatedId      String?
  tags           Json?
  metadata       Json?
  isTemplate     Boolean              @default(false)
  isPublic       Boolean              @default(false)
  isSigned       Boolean              @default(false)
  signedAt       DateTime?
  signedBy       String?
  ocrProcessed   Boolean              @default(false)
  ocrText        String?
  aiGenerated    Boolean              @default(false)
  aiGenerationId String?
  version        Int                  @default(1)
  createdAt      DateTime             @default(now())
  updatedAt      DateTime             @updatedAt
  aiGeneration   ai_generations?      @relation(fields: [aiGenerationId], references: [id])
  category       document_categories? @relation(fields: [categoryId], references: [id])
  properties     properties?          @relation(fields: [propertyId], references: [id])
  prospects      prospects?           @relation(fields: [prospectId], references: [id])
  users          users                @relation("UserDocuments", fields: [userId], references: [id], onDelete: Cascade)
  ocr_results    ocr_results[]

  @@index([userId])
  @@index([categoryId])
  @@index([prospectId])
  @@index([propertyId])
  @@index([relatedType, relatedId])
}

model document_templates {
  id          String   @id @default(cuid())
  userId      String
  name        String
  description String?
  content     String
  variables   Json
  category    String?
  mimeType    String   @default("text/html")
  isActive    Boolean  @default(true)
  isPublic    Boolean  @default(false)
  usageCount  Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  users       users    @relation("UserDocumentTemplates", fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([category])
}

model ai_generations {
  id             String      @id @default(cuid())
  userId         String
  provider       String
  model          String
  prompt         String
  response       String
  type           String?
  documentType   String?
  tokensUsed     Int?
  cost           Float?
  temperature    Float?
  maxTokens      Int?
  status         String      @default("completed")
  prospectType   String?
  subType        String?
  searchCriteria Json?
  mandatInfo     Json?
  profiling      Json?
  timeline       String?
  budget         Json?
  errorMessage   String?
  metadata       Json?
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt
  users          users       @relation("UserAiGenerations", fields: [userId], references: [id], onDelete: Cascade)
  documents      documents[]

  @@index([userId])
  @@index([provider])
  @@index([status])
}

model ocr_results {
  id             String     @id @default(cuid())
  userId         String
  documentId     String?
  imageUrl       String
  extractedText  String
  text           String?
  language       String     @default("fra+eng")
  confidence     Float?
  processingTime Int?
  engine         String     @default("tesseract")
  metadata       Json?
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt
  document       documents? @relation(fields: [documentId], references: [id])
  users          users      @relation("UserOcrResults", fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([documentId])
}

model ai_settings {
  id                String   @id @default(cuid())
  userId            String   @unique
  defaultProvider   String   @default("openai")
  preferredProvider String?  @default("openai")
  // ── LLM Providers ──
  openaiApiKey      String?
  geminiApiKey      String?
  claudeApiKey      String?       // Anthropic
  deepseekApiKey    String?
  openrouterApiKey  String?

  // ── Scraping & Data Providers ──
  serpApiKey          String?     // Google SERP API
  firecrawlApiKey     String?     // Firecrawl web scraping
  picaApiKey          String?     // Pica real estate data
  jinaReaderApiKey    String?     // Jina Reader (URL → Markdown)
  scrapingBeeApiKey   String?     // ScrapingBee
  browserlessApiKey   String?     // Browserless headless browser
  rapidApiKey         String?     // RapidAPI

  customApiKeys     Json?
  defaultModel      String?
  temperature       Float    @default(0.7)
  maxTokens         Int      @default(2000)
  preferences       Json?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  users             users    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model prospecting_campaigns {
  id             String              @id @default(cuid())
  userId         String
  name           String
  description    String?
  type           String              // CampaignType as string for flexibility
  config         Json
  status         CampaignStatus      @default(draft)
  prospectType   String?
  subType        String?
  searchCriteria Json?
  mandatInfo     Json?
  profiling      Json?
  timeline       String?
  budget         Json?
  targetCount    Int?
  foundCount     Int                 @default(0)
  matchedCount   Int                 @default(0)
  startedAt      DateTime?
  completedAt    DateTime?
  createdAt      DateTime            @default(now())
  updatedAt      DateTime            @updatedAt
  users          users               @relation("UserProspectingCampaigns", fields: [userId], references: [id], onDelete: Cascade)
  leads          prospecting_leads[]

  @@index([userId])
  @@index([status])
  @@index([type])
  @@index([userId, status, createdAt])
  @@index([startedAt])
  @@index([foundCount, matchedCount])
}

model prospecting_leads {
  id                  String                @id @default(cuid())
  campaignId          String
  userId              String
  firstName           String?
  lastName            String?
  email               String?
  phone               String?
  address             String?
  city                String?
  zipCode             String?
  country             String?               @default("Tunisie")
  propertyType        String?
  propertyTypes       String[]              // Array of property types from LLM
  source              String?
  sourceUrl           String?
  rawText             String?               @db.Text // Original scraped text
  title               String?               // Title from scraped content
  score               Int                   @default(0)
  status              LeadStatus            @default(new)
  leadType            LeadType              @default(inconnu)
  intention           Intention?
  urgency             Urgency?
  validationStatus    ValidationStatus      @default(pending)
  seriousnessScore    Int?                  // 0-100 from LLM analysis
  surfaceM2           Int?                  // Surface in square meters
  rooms               Int?                  // Number of rooms
  budgetMin           Float?                // Minimum budget
  budgetMax           Float?                // Maximum budget
  budgetCurrency      String?               @default("TND")
  qualificationNotes  String?               @db.Text // Notes de qualification du lead

  // ✅ NOUVEAUX CHAMPS TRACKING
  retryCount          Int                   @default(0)  // Nombre de tentatives de contact
  lastContactedAt     DateTime?                          // Dernière tentative de contact
  nextActionDate      DateTime?                          // Prochaine action planifiée
  sourceMetadata      Json?                              // Métadonnées du scraping
  qualityScore        Int?                               // Score qualité 0-100
  aiModelVersion      String?                            // Version du modèle LLM utilisé

  // ⚠️ DEPRECATED FIELDS - À SUPPRIMER DANS PROCHAINE VERSION
  prospectType        String?               // @deprecated - Use leadType
  subType             String?               // @deprecated
  searchCriteria      Json?                 // @deprecated
  mandatInfo          Json?                 // @deprecated
  profiling           Json?                 // @deprecated
  timeline            String?               // @deprecated - Use urgency
  budget              Json?                 // @deprecated - Use budgetMin/budgetMax
  matchedPropertyIds  String[]              // @deprecated - Use prospecting_lead_properties junction table

  metadata            Json?
  convertedProspectId String?
  convertedAt         DateTime?
  createdAt           DateTime              @default(now())
  updatedAt           DateTime              @updatedAt
  campaigns           prospecting_campaigns @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  convertedProspect   prospects?                        @relation("ConvertedProspect", fields: [convertedProspectId], references: [id])
  users               users                             @relation("UserProspectingLeads", fields: [userId], references: [id], onDelete: Cascade)
  prospecting_matches prospecting_matches[]             @relation("LeadMatches")
  matchedProperties   prospecting_lead_properties[]     @relation("LeadPropertyMatches")

  @@index([campaignId])
  @@index([userId])
  @@index([status])
  @@index([score])
  @@index([email])
  @@index([leadType])
  @@index([validationStatus])
  @@index([city])
  @@index([campaignId, status, leadType])
