generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================
// PROSPECTING
// ============================================
model ProspectingSource {
  id          String    @id @default(cuid())
  name        String
  url         String?
  type        String
  config      Json?
  lastScraped DateTime?
  isActive    Boolean   @default(true)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

// ============================================
// AGENCIES
// ============================================
model agencies {
  id         String       @id @default(cuid())
  name       String
  address    String?
  phone      String?
  email      String?
  createdAt  DateTime     @default(now())
  updatedAt  DateTime     @updatedAt
  properties properties[]
  prospects  prospects[]
  users      users[]
}

// ============================================
// APPOINTMENTS
// ============================================
model appointments {
  id            String     @id @default(cuid())
  userId        String
  prospectId    String?
  propertyId    String?
  tasks                tasks[]               @relation("AppointmentTasks")
  title         String
  description   String?
  startTime     DateTime
  endTime       DateTime
  location      String?
  type          String     @default("visit") // visit, signature, expertise, estimation, meeting, other
  status        String     @default("scheduled") // scheduled, confirmed, completed, cancelled, rescheduled, no_show
  prospectType      String?   // requete_location, requete_achat, mandat_location, mandat_vente, promoteur
  subType           String?   // Type de bien recherché ou à vendre
  searchCriteria    Json?     // Critères de recherche structurés
  mandatInfo        Json?     // Informations mandat si applicable
  profiling         Json?     // Profiling enrichi du prospect
  timeline          String?   // Timeline souhaitée
  budget            Json?     // Budget min/max
  priority      String     @default("medium") // low, medium, high, urgent
  isAllDay      Boolean    @default(false)
  reminder      Boolean    @default(true)
  reminderSent  Boolean    @default(false)
  reminderTime  Int?       @default(60) // minutes before
  attendees     Json?      // Array of attendee objects
  notes         String?
  outcome       String?    // Result after appointment
  rating        Int?       // 1-5 rating
  googleEventId String?
  iCalUid       String?
  recurrence    Json?      // Recurrence rules
  color         String?    @default("#3B82F6")
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt
  
  prospects     prospects? @relation(fields: [prospectId], references: [id], onDelete: SetNull)
  properties    properties? @relation(fields: [propertyId], references: [id], onDelete: SetNull)
  users         users      @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  @@index([userId])
  @@index([prospectId])
  @@index([propertyId])
  @@index([startTime])
  @@index([status])
  @@index([type])
}

// ============================================
// CAMPAIGNS
// ============================================
model campaigns {
  id          String    @id @default(cuid())
  userId      String
  name        String
  description String?   // 🆕 ADDED: Campaign description
  type        String
  status      String    @default("draft")
  prospectType      String?   // requete_location, requete_achat, mandat_location, mandat_vente, promoteur
  subType           String?   // Type de bien recherché ou à vendre
  searchCriteria    Json?     // Critères de recherche structurés
  mandatInfo        Json?     // Informations mandat si applicable
  profiling         Json?     // Profiling enrichi du prospect
  timeline          String?   // Timeline souhaitée
  budget            Json?     // Budget min/max
  content     Json
  recipients  Json
  scheduledAt DateTime?
  sentAt      DateTime?
  stats       Json?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  users       users     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// ============================================
// MATCHES
// ============================================
model matches {
  id         String     @id @default(cuid())
  propertyId String
  prospectId String
  score      Float
  reasons    Json?
  status     String     @default("pending")
  prospectType      String?   // requete_location, requete_achat, mandat_location, mandat_vente, promoteur
  subType           String?   // Type de bien recherché ou à vendre
  searchCriteria    Json?     // Critères de recherche structurés
  mandatInfo        Json?     // Informations mandat si applicable
  profiling         Json?     // Profiling enrichi du prospect
  timeline          String?   // Timeline souhaitée
  budget            Json?     // Budget min/max
  createdAt  DateTime   @default(now())
  updatedAt  DateTime   @updatedAt
  properties properties @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  prospects  prospects  @relation(fields: [prospectId], references: [id], onDelete: Cascade)

  @@unique([propertyId, prospectId])
}

// ============================================
// PROPERTIES
// ============================================
model properties {
  id             String           @id @default(cuid())
  userId         String
  agencyId       String?
  reference      String?          // 🆕 ADDED: Property reference number
  title          String
  description    String?
  type           String
  category       String
  price          Float
  currency       String           @default("TND")
  address        String?
  city           String?
  delegation     String?
  zipCode        String?
  latitude       Float?
  longitude      Float?
  bedrooms       Int?
  bathrooms      Int?
  area           Float?
  images         Json?
  features       Json?
  status         String           @default("available")
  viewsCount     Int              @default(0) // 🆕 ADDED: Number of views
  prospectType      String?   // requete_location, requete_achat, mandat_location, mandat_vente, promoteur
  subType           String?   // Type de bien recherché ou à vendre
  searchCriteria    Json?     // Critères de recherche structurés
  mandatInfo        Json?     // Informations mandat si applicable
  profiling         Json?     // Profiling enrichi du prospect
  timeline          String?   // Timeline souhaitée
  budget            Json?     // Budget min/max
  wpSyncId       String?
  wpSyncedAt     DateTime?
  wordpressId    String?
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt
  matches        matches[]
  communications communications[]
  documents      documents[]
  appointments   appointments[]
  tasks                tasks[]               @relation("PropertyTasks")
  prospectShown             prospect_properties_shown[]   @relation("PropertyProspectShown")
  prospecting_matches  prospecting_matches[] @relation("PropertyMatches")
  agencies       agencies?        @relation(fields: [agencyId], references: [id])
  users          users            @relation(fields: [userId], references: [id], onDelete: Cascade)
  publishedProperty     PublishedProperty[]
  vitrineAnalytics      VitrineAnalytics[]
  propertySeo           PropertySeo?
}

// ============================================
// PROSPECTS
// ============================================
model prospects {
  id             String           @id @default(cuid())
  userId         String
  agencyId       String?
  firstName      String?
  lastName       String?
  email          String?
  phone          String?
  type           String
  currency       String           @default("TND")
  preferences    Json?
  source         String?
  status         String           @default("active")
  score          Int              @default(0) // 🆕 ADDED: Qualification score 0-100
  prospectType      String?   // requete_location, requete_achat, mandat_location, mandat_vente, promoteur
  subType           String?   // Type de bien recherché ou à vendre
  searchCriteria    Json?     // Critères de recherche structurés
  mandatInfo        Json?     // Informations mandat si applicable
  profiling         Json?     // Profiling enrichi du prospect
  timeline          String?   // Timeline souhaitée
  budget            Json?     // Budget min/max
  notes          String?
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt
  appointments   appointments[]
  matches        matches[]
  timelineStages            prospect_timeline[]           @relation("ProspectTimeline")
  propertiesShown           prospect_properties_shown[]   @relation("ProspectPropertiesShown")
  interactions     prospect_interactions[]   @relation("ProspectInteractions")
  preferences_details  prospect_preferences[]    @relation("ProspectPreferences")
  communications communications[]
  documents      documents[]
  prospecting_matches  prospecting_matches[] @relation("ProspectMatches")
  contact_validations  contact_validations[] @relation("ProspectValidations")
  tasks                tasks[]               @relation("ProspectTasks")
  converted_from_leads prospecting_leads[]   @relation("ConvertedProspect")
  agencies       agencies?        @relation(fields: [agencyId], references: [id])
  users          users            @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// ============================================
// USER INTEGRATIONS
// ============================================
model user_integrations {
  id        String   @id @default(cuid())
  userId    String
  type      String
  apiKey    String
  config    Json?
  data      Json?    // 🆕 ADDED: Additional integration data
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  users     users    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, type])
}

// ============================================
// USERS
// ============================================
model users {
  id                       String                    @id @default(cuid())
  email                    String                    @unique
  password                 String
  firstName                String?
  lastName                 String?
  role                     String                    @default("agent")
  agencyId                 String?
  createdAt                DateTime                  @default(now())
  updatedAt                DateTime                  @updatedAt
  appointments             appointments[]
  campaigns                campaigns[]
  properties               properties[]
  prospects                prospects[]
  user_integrations        user_integrations[]
  communications           communications[]          @relation("UserCommunications")
  communication_templates  communication_templates[] @relation("UserCommunicationTemplates")
  documents                documents[]               @relation("UserDocuments")
  document_templates       document_templates[]      @relation("UserDocumentTemplates")
  analytics_events      analytics_events[]    @relation("UserAnalyticsEvents")
  settings              settings[]            @relation("UserSettings")
  prospect_interactions     prospect_interactions[]   @relation("UserProspectInteractions")
  ai_generations           ai_generations[]          @relation("UserAiGenerations")
  ocr_results              ocr_results[]             @relation("UserOcrResults")
  tasks                 tasks[]               @relation("UserTasks")
  contact_validations   contact_validations[] @relation("UserContactValidations")
  ai_settings              ai_settings?
  prospecting_campaigns    prospecting_campaigns[]   @relation("UserProspectingCampaigns")
  prospecting_leads        prospecting_leads[]       @relation("UserProspectingLeads")
  agencies                 agencies?                 @relation(fields: [agencyId], references: [id])
  vitrineConfig            VitrineConfig?
  publishedProperties      PublishedProperty[]
  vitrineAnalytics         VitrineAnalytics[]
  seoConfig                SeoConfig?
  seoBlogPosts             SeoBlogPost[]
  llmConfig                LlmConfig?
  pages                    Page[]
  trackingConfigs          TrackingConfig[]
  trackingEvents           TrackingEvent[]
  mlConfig                 MlConfig?
  aiSuggestions            AiSuggestion[]
  detectedAnomalies        DetectedAnomaly[]
  ai_usage_metrics         ai_usage_metrics[]        @relation("UserAiUsageMetrics")
  conversion_events        conversion_events[]       @relation("UserConversionEvents")
  notifications            Notification[]            @relation("UserNotifications")
  activities               Activity[]                @relation("UserActivities")
  wordpressUrl             String?
  wordpressUsername        String?
  wordpressPassword        String?
}

// ============================================
// COMMUNICATIONS MODULE
// ============================================
model communications {
  id                  String                   @id @default(cuid())
  userId              String
  type                String                   // email, sms, whatsapp
  to                  String
  from                String?
  subject             String?
  body                String                   @db.Text
  status              String                   @default("sent") // sent, delivered, opened, clicked, failed
  prospectType      String?   // requete_location, requete_achat, mandat_location, mandat_vente, promoteur
  subType           String?   // Type de bien recherché ou à vendre
  searchCriteria    Json?     // Critères de recherche structurés
  mandatInfo        Json?     // Informations mandat si applicable
  profiling         Json?     // Profiling enrichi du prospect
  timeline          String?   // Timeline souhaitée
  budget            Json?     // Budget min/max
  sentAt              DateTime                 @default(now())
  deliveredAt         DateTime?
  openedAt            DateTime?
  clickedAt           DateTime?
  failedReason        String?
  prospectId          String?
  propertyId          String?
  templateId          String?
  metadata            Json?
  createdAt           DateTime                 @default(now())
  updatedAt           DateTime                 @updatedAt
  users               users                    @relation("UserCommunications", fields: [userId], references: [id], onDelete: Cascade)
  prospects           prospects?               @relation(fields: [prospectId], references: [id])
  properties          properties?              @relation(fields: [propertyId], references: [id])
  template            communication_templates? @relation(fields: [templateId], references: [id])

  @@index([userId])
  @@index([prospectId])
  @@index([type])
  @@index([status])
}

model communication_templates {
  id             String           @id @default(cuid())
  userId         String
  name           String
  type           String           // email, sms, whatsapp
  subject        String?
  content        String           @db.Text
  variables      Json             // Liste des variables utilisables
  isActive       Boolean          @default(true)
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt
  users          users            @relation("UserCommunicationTemplates", fields: [userId], references: [id], onDelete: Cascade)
  communications communications[]

  @@index([userId])
  @@index([type])
}

// ============================================
// DOCUMENTS MODULE
// ============================================
model document_categories {
  id          String      @id @default(cuid())
  name        String
  description String?
  color       String?
  icon        String?
  parentId    String?
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  documents   documents[]
  parent      document_categories?  @relation("CategoryHierarchy", fields: [parentId], references: [id])
  children    document_categories[] @relation("CategoryHierarchy")

  @@index([parentId])
}

model documents {
  id              String               @id @default(cuid())
  userId          String
  categoryId      String?
  name            String
  originalName    String
  description     String?
  fileUrl         String
  filePath        String
  mimeType        String
  fileSize        Int
  extension       String
  prospectId      String?
  propertyId      String?
  relatedType     String?              // prospect, property, contract, etc.
  relatedId       String?
  tags            Json?
  metadata        Json?
  isTemplate      Boolean              @default(false)
  isPublic        Boolean              @default(false)
  isSigned        Boolean              @default(false)
  signedAt        DateTime?
  signedBy        String?
  ocrProcessed    Boolean              @default(false)
  ocrText         String?              @db.Text
  aiGenerated     Boolean              @default(false)
  aiGenerationId  String?
  version         Int                  @default(1)
  createdAt       DateTime             @default(now())
  updatedAt       DateTime             @updatedAt
  users           users                @relation("UserDocuments", fields: [userId], references: [id], onDelete: Cascade)
  category        document_categories? @relation(fields: [categoryId], references: [id])
  prospects       prospects?           @relation(fields: [prospectId], references: [id])
  properties      properties?          @relation(fields: [propertyId], references: [id])
  aiGeneration    ai_generations?      @relation(fields: [aiGenerationId], references: [id])
  ocr_results     ocr_results[]        // 🆕 ADDED: Relation from documents to OCR results

  @@index([userId])
  @@index([categoryId])
  @@index([prospectId])
  @@index([propertyId])
  @@index([relatedType, relatedId])
}

model document_templates {
  id           String   @id @default(cuid())
  userId       String
  name         String
  description  String?
  content      String   @db.Text
  variables    Json     // Variables disponibles
  category     String?
  mimeType     String   @default("text/html")
  isActive     Boolean  @default(true)
  isPublic     Boolean  @default(false)
  usageCount   Int      @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  users        users    @relation("UserDocumentTemplates", fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([category])
}

model ai_generations {
  id               String      @id @default(cuid())
  userId           String
  provider         String      // openai, gemini, claude, deepseek, openrouter, etc.
  model            String
  prompt           String      @db.Text
  response         String      @db.Text
  type             String?     // 🆕 ADDED: Generation type (document_generation, email_validation, etc.)
  documentType     String?     // contract, email, report, etc.
  tokensUsed       Int?
  cost             Float?
  temperature      Float?
  maxTokens        Int?
  status           String      @default("completed") // pending, completed, failed
  prospectType      String?   // requete_location, requete_achat, mandat_location, mandat_vente, promoteur
  subType           String?   // Type de bien recherché ou à vendre
  searchCriteria    Json?     // Critères de recherche structurés
  mandatInfo        Json?     // Informations mandat si applicable
  profiling         Json?     // Profiling enrichi du prospect
  timeline          String?   // Timeline souhaitée
  budget            Json?     // Budget min/max
  errorMessage     String?
  metadata         Json?
  createdAt        DateTime    @default(now())
  updatedAt        DateTime    @updatedAt
  users            users       @relation("UserAiGenerations", fields: [userId], references: [id], onDelete: Cascade)
  documents        documents[]

  @@index([userId])
  @@index([provider])
  @@index([status])
}

model ocr_results {
  id           String   @id @default(cuid())
  userId       String
  documentId   String?
  imageUrl     String
  extractedText String  @db.Text
  text         String?  @db.Text // 🆕 ADDED: Alias for extractedText (compatibility)
  language     String   @default("fra+eng")
  confidence   Float?
  processingTime Int?   // milliseconds
  engine       String   @default("tesseract") // tesseract, google-vision, aws-textract
  metadata     Json?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  users        users    @relation("UserOcrResults", fields: [userId], references: [id], onDelete: Cascade)
  document     documents? @relation(fields: [documentId], references: [id]) // 🆕 ADDED: Relation to documents

  @@index([userId])
  @@index([documentId])
}

model ai_settings {
  id              String   @id @default(cuid())
  userId          String   @unique
  defaultProvider String   @default("openai") // openai, gemini, claude, deepseek, openrouter
  preferredProvider String? @default("openai") // 🆕 ADDED: Preferred AI provider
  openaiApiKey    String?
  geminiApiKey    String?
  claudeApiKey    String?
  deepseekApiKey  String?
  openrouterApiKey String?
  customApiKeys   Json?    // Pour d'autres providers
  defaultModel    String?
  temperature     Float    @default(0.7)
  maxTokens       Int      @default(2000)
  preferences     Json?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  users           users    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

// ============================================
// PROSPECTION INTELLIGENTE
// ============================================

model prospecting_campaigns {
  id          String    @id @default(cuid())
  userId      String
  name        String
  description String?
  type        String    // geographic, demographic, behavioral, custom
  config      Json      // Configuration du scraping
  status      String    @default("draft") // draft, active, paused, completed
  prospectType      String?   // requete_location, requete_achat, mandat_location, mandat_vente, promoteur
  subType           String?   // Type de bien recherché ou à vendre
  searchCriteria    Json?     // Critères de recherche structurés
  mandatInfo        Json?     // Informations mandat si applicable
  profiling         Json?     // Profiling enrichi du prospect
  timeline          String?   // Timeline souhaitée
  budget            Json?     // Budget min/max
  targetCount Int?
  foundCount  Int       @default(0)
  matchedCount Int      @default(0)
  startedAt   DateTime?
  completedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  
  users       users     @relation("UserProspectingCampaigns", fields: [userId], references: [id], onDelete: Cascade)
  leads       prospecting_leads[]
  
  @@index([userId])
  @@index([status])
  @@index([type])
}

model prospecting_leads {
  id            String    @id @default(cuid())
  campaignId    String
  userId        String
  firstName     String?
  lastName      String?
  email         String?
  phone         String?
  address       String?
  city          String?
  zipCode       String?
  propertyType  String?
  source        String?   // linkedin, facebook, scraping, etc.
  sourceUrl     String?
  score         Int       @default(0) // 0-100
  status        String    @default("new") // new, contacted, qualified, converted, rejected
  prospectType      String?   // requete_location, requete_achat, mandat_location, mandat_vente, promoteur
  subType           String?   // Type de bien recherché ou à vendre
  searchCriteria    Json?     // Critères de recherche structurés
  mandatInfo        Json?     // Informations mandat si applicable
  profiling         Json?     // Profiling enrichi du prospect
  timeline          String?   // Timeline souhaitée
  budget            Json?     // Budget min/max
  matchedPropertyIds Json?
  metadata      Json?     // Données additionnelles du scraping
  convertedProspectId String?
  convertedAt   DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  
  campaigns     prospecting_campaigns @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  users         users     @relation("UserProspectingLeads", fields: [userId], references: [id], onDelete: Cascade)
  convertedProspect prospects? @relation("ConvertedProspect", fields: [convertedProspectId], references: [id], onDelete: SetNull)
  
  @@index([campaignId])
  @@index([userId])
  @@index([status])
  @@index([score])
  @@index([email])
}

model prospecting_matches {
  id          String    @id @default(cuid())
  leadId      String
  prospectId  String?
  propertyId  String
  score       Int       // 0-100
  reason      Json      // Raisons du match
  status      String    @default("pending") // pending, notified, contacted, converted, ignored
  prospectType      String?   // requete_location, requete_achat, mandat_location, mandat_vente, promoteur
  subType           String?   // Type de bien recherché ou à vendre
  searchCriteria    Json?     // Critères de recherche structurés
  mandatInfo        Json?     // Informations mandat si applicable
  profiling         Json?     // Profiling enrichi du prospect
  timeline          String?   // Timeline souhaitée
  budget            Json?     // Budget min/max
  notifiedAt  DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  
  prospects   prospects? @relation("ProspectMatches", fields: [prospectId], references: [id], onDelete: SetNull)
  properties  properties @relation("PropertyMatches", fields: [propertyId], references: [id], onDelete: Cascade)
  
  @@index([leadId])
  @@index([prospectId])
  @@index([propertyId])
  @@index([score])
  @@index([status])
}

// ============================================
// VALIDATION & VERIFICATION MODULE
// ============================================

model contact_validations {
  id              String    @id @default(cuid())
  userId          String
  contactType     String    // email, phone, address
  contactValue    String
  isValid         Boolean   @default(false)
  score           Int       @default(0) // 0-100
  validationMethod String?  // syntax, dns, mx, api, manual
  reason          String?   // Raison si invalide
  isSpam          Boolean   @default(false)
  isDisposable    Boolean   @default(false)
  isCatchAll      Boolean   @default(false)
  provider        String?   // Gmail, Outlook, etc.
  metadata        Json?
  prospectId      String?
  leadId          String?
  verifiedAt      DateTime  @default(now())
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  
  users           users     @relation("UserContactValidations", fields: [userId], references: [id], onDelete: Cascade)
  prospects       prospects? @relation("ProspectValidations", fields: [prospectId], references: [id], onDelete: SetNull)
  
  @@index([userId])
  @@index([contactValue])
  @@index([isValid])
  @@index([isSpam])
  @@index([prospectId])
}

model validation_blacklist {
  id          String    @id @default(cuid())
  type        String    // email, phone, domain, ip
  value       String    @unique
  reason      String?
  addedBy     String?
  isActive    Boolean   @default(true)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  
  @@index([type])
  @@index([value])
  @@index([isActive])
}

model validation_whitelist {
  id          String    @id @default(cuid())
  type        String    // email, phone, domain
  value       String    @unique
  addedBy     String?
  isActive    Boolean   @default(true)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  
  @@index([type])
  @@index([value])
  @@index([isActive])
}

model disposable_domains {
  id          String    @id @default(cuid())
  domain      String    @unique
  isActive    Boolean   @default(true)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  
  @@index([domain])
  @@index([isActive])
}

// ============================================
// TASKS MODULE
// ============================================

model tasks {
  id              String    @id @default(cuid())
  userId          String
  title           String
  description     String?
  status          String    @default("todo") // todo, in_progress, done, cancelled
  prospectType      String?   // requete_location, requete_achat, mandat_location, mandat_vente, promoteur
  subType           String?   // Type de bien recherché ou à vendre
  searchCriteria    Json?     // Critères de recherche structurés
  mandatInfo        Json?     // Informations mandat si applicable
  profiling         Json?     // Profiling enrichi du prospect
  timeline          String?   // Timeline souhaitée
  budget            Json?     // Budget min/max
  priority        String    @default("medium") // low, medium, high, urgent
  dueDate         DateTime?
  completedAt     DateTime?
  prospectId      String?
  propertyId      String?
  appointmentId   String?
  tags            Json?
  assignedTo      String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  
  users           users     @relation("UserTasks", fields: [userId], references: [id], onDelete: Cascade)
  prospects       prospects? @relation("ProspectTasks", fields: [prospectId], references: [id], onDelete: SetNull)
  properties      properties? @relation("PropertyTasks", fields: [propertyId], references: [id], onDelete: SetNull)
  appointments    appointments? @relation("AppointmentTasks", fields: [appointmentId], references: [id], onDelete: SetNull)
  
  @@index([userId])
  @@index([status])
  @@index([priority])
  @@index([dueDate])
  @@index([prospectId])
  @@index([propertyId])
}

// ============================================
// ANALYTICS MODULE
// ============================================

model analytics_events {
  id              String    @id @default(cuid())
  userId          String
  eventType       String    // page_view, action, conversion, etc.
  eventName       String
  metadata        Json?
  timestamp       DateTime  @default(now())
  
  users           users     @relation("UserAnalyticsEvents", fields: [userId], references: [id], onDelete: Cascade)
  
  @@index([userId])
  @@index([eventType])
  @@index([timestamp])
}

// ============================================
// SETTINGS MODULE
// ============================================

model settings {
  id          String    @id @default(cuid())
  section     String    // ai-providers, firecrawl, serpapi, etc.
  key         String
  value       String?   @db.Text
  type        String    @default("string") // string, number, boolean, json
  encrypted   Boolean   @default(false)
  description String?   @db.Text
  userId      String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  
  users       users?    @relation("UserSettings", fields: [userId], references: [id], onDelete: Cascade)
  
  @@unique([section, key, userId])
  @@index([section])
  @@index([userId])
  @@index([section, userId])
}

// ============================================
// PROSPECTS AMÉLIORATION - SYSTÈME COMPLET
// ============================================

model prospect_interactions {
  id                String    @id @default(cuid())
  prospectId        String
  userId            String
  date              DateTime  @default(now())
  channel           String    // phone, email, whatsapp, sms, meeting, visit
  type              String    // call, email, visit, offer, negotiation, feedback
  subject           String?
  notes             String?   @db.Text
  nextAction        String?
  nextActionDate    DateTime?
  sentiment         String?   // positive, neutral, negative
  propertyShown     String?   // ID du bien montré
  feedback          Json?
  createdAt         DateTime  @default(now())
  
  prospects         prospects @relation("ProspectInteractions", fields: [prospectId], references: [id], onDelete: Cascade)
  users             users     @relation("UserProspectInteractions", fields: [userId], references: [id], onDelete: Cascade)
  
  @@index([prospectId])
  @@index([userId])
  @@index([date])
  @@index([nextActionDate])
}

model prospect_preferences {
  id          String    @id @default(cuid())
  prospectId  String
  category    String    // location, features, neighborhood, style, etc.
  liked       Json?     // Array de ce qu'il aime
  disliked    Json?     // Array de ce qu'il n'aime pas (deal breakers)
  priority    Int       @default(1) // Ordre d'importance
  notes       String?   @db.Text
  updatedAt   DateTime  @updatedAt
  
  prospects   prospects @relation("ProspectPreferences", fields: [prospectId], references: [id], onDelete: Cascade)
  
  @@index([prospectId])
  @@index([category])
}

model prospect_timeline {
  budget            Json?     // Budget min/max
  id          String    @id @default(cuid())
  prospectId  String
  stage       String    // discovery, qualification, presentation, negotiation, closing, etc.
  enteredAt   DateTime  @default(now())
  exitedAt    DateTime?
  duration    Int?      // Durée en minutes
  outcome     String?   // completed, skipped, failed
  notes       String?   @db.Text
  
  prospects   prospects @relation("ProspectTimeline", fields: [prospectId], references: [id], onDelete: Cascade)
  
  @@index([prospectId])
  @@index([stage])
  @@index([enteredAt])
}

model prospect_properties_shown {
  id            String    @id @default(cuid())
  prospectId    String
  propertyId    String
  shownDate     DateTime  @default(now())
  visitType     String?   // virtual, physical, photos
  feedback      String?   @db.Text
  interestLevel Int?      // 1-10
  reasons       Json?     // Raisons du like/dislike
  outcome       String?   // interested, rejected, maybe
  createdAt     DateTime  @default(now())
  
  prospects     prospects  @relation("ProspectPropertiesShown", fields: [prospectId], references: [id], onDelete: Cascade)
  properties    properties @relation("PropertyProspectShown", fields: [propertyId], references: [id], onDelete: Cascade)
  
  @@index([prospectId])
  @@index([propertyId])
  @@index([shownDate])
  @@index([interestLevel])
}

// ========================================
// MODULE VITRINE PUBLIQUE
// ========================================

model VitrineConfig {
  id              String   @id @default(cuid())
  userId          String   @unique
  isActive        Boolean  @default(false)
  agencyName      String
  logo            String?
  slogan          String?
  primaryColor    String   @default("#3B82F6")
  secondaryColor  String   @default("#10B981")
  phone           String
  email           String
  address         String?
  schedule        Json?
  socialLinks     Json?
  theme           String   @default("light")
  heroImage       String?
  aboutText       String?
  services        Json?
  testimonials    Json?
  seoTitle        String?
  seoDescription  String?
  seoKeywords     String?
  analyticsId     String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  
  user users @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model PublishedProperty {
  id          String   @id @default(cuid())
  propertyId  String
  userId      String
  isFeatured  Boolean  @default(false)
  order       Int      @default(0)
  publishedAt DateTime @default(now())
  
  property properties @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  user users @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  @@unique([propertyId, userId])
  @@index([userId])
  @@index([isFeatured])
}

model VitrineAnalytics {
  id         String    @id @default(cuid())
  userId     String
  date       DateTime  @default(now())
  pageViews  Int       @default(0)
  visitors   Int       @default(0)
  propertyId String?
  source     String?
  
  user users @relation(fields: [userId], references: [id], onDelete: Cascade)
  property   properties? @relation(fields: [propertyId], references: [id], onDelete: SetNull)
  
  @@index([userId, date])
  @@index([propertyId])
}

// ========================================
// MODULE SEO AI
// ========================================

model PropertySeo {
  id            String    @id @default(cuid())
  propertyId    String    @unique
  metaTitle     String?
  metaDescription String?
  slug          String    @unique
  keywords      String[]
  altTexts      Json?
  faq           Json?
  schemaOrg     Json?
  seoScore      Int       @default(0)
  lastOptimized DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  
  property      properties  @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  
  @@index([propertyId])
  @@index([seoScore])
  @@index([slug])
}

model SeoConfig {
  id             String   @id @default(cuid())
  userId         String   @unique
  aiProvider     String   @default("claude")
  language       String   @default("fr")
  tone           String   @default("professional")
  targetKeywords String[]
  geoArea        String[]
  autoOptimize   Boolean  @default(true)
  blogFrequency  String   @default("weekly")
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  
  user users @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model SeoBlogPost {
  id          String   @id @default(cuid())
  userId      String
  title       String
  slug        String   @unique
  content     String   @db.Text
  excerpt     String?
  keywords    String[]
  metaTitle   String?
  metaDesc    String?
  publishedAt DateTime @default(now())
  views       Int      @default(0)
  
  user users @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  @@index([userId])
  @@index([publishedAt])
}

// ========================================
// MODULE LLM CONFIG (Multi-Provider)
// ========================================

model LlmConfig {
  id                  String   @id @default(cuid())
  userId              String   @unique
  provider            String   @default("anthropic")
  apiKey              String?
  model               String?
  defaultMaxTokens    Int?     @default(1000)
  defaultTemperature  Float?   @default(0.7)
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
  
  user users @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  @@index([userId])
  @@index([provider])
}

// ========================================
// MODULE PAGE BUILDER
// ========================================

model Page {
  id          String   @id @default(cuid())
  userId      String
  title       String
  slug        String
  description String?
  blocks      Json     @default("[]")
  isPublished Boolean  @default(false)
  template    String?
  seo         Json?
  views       Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  user users @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  @@unique([userId, slug])
  @@index([userId])
  @@index([slug])
  @@index([isPublished])
