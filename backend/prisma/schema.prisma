// ═══════════════════════════════════════════════════════
// LLM ROUTER - Multi-providers support
// ═══════════════════════════════════════════════════════

model UserLlmProvider {
  id            String  @id @default(cuid())
  userId        String
  provider      String // 'anthropic', 'openai', 'gemini', 'openrouter', 'deepseek', 'qwen', 'kimi', 'mistral'
  apiKey        String // Clé API (cryptée)
  model         String? // Modèle par défaut pour ce provider
  isActive      Boolean @default(true)
  priority      Int     @default(0) // 0 = plus haute priorité
  monthlyBudget Float? // Budget mensuel pour ce provider (en $)

  // ✅ NOUVEAUX CHAMPS TRACKING
  monthlyTokensUsed    Int       @default(0) // Tokens utilisés ce mois
  estimatedMonthCost   Float     @default(0) // Coût estimé ce mois
  quotaRemainingTokens Int? // Tokens restants (quota API)
  rateLimitPerMinute   Int? // Rate limit du provider
  lastUsedAt           DateTime? // Dernière utilisation
  successRate          Float     @default(100) // Taux de succès (0-100%)
  failureCount         Int       @default(0) // Nombre d'échecs
  totalApiCalls        Int       @default(0) // Total d'appels API

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  user               users                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  usageLogs          LlmUsageLog[]         @relation("ProviderUsageLogs")
  performanceMetrics ProviderPerformance[] @relation("ProviderMetrics")

  @@unique([userId, provider])
  @@index([userId])
  @@index([userId, isActive])
  @@index([lastUsedAt])
  @@index([successRate])
  @@map("user_llm_providers")
}

model LlmUsageLog {
  id                String   @id @default(cuid())
  userId            String
  userLlmProviderId String? // FK vers UserLlmProvider (optionnel car peut être un provider non configuré)
  provider          String // Provider utilisé
  operationType     String // 'seo', 'prospecting_mass', 'analysis_quick', etc.
  tokensInput       Int      @default(0)
  tokensOutput      Int      @default(0)
  cost              Float    @default(0) // Coût en $
  latency           Int      @default(0) // Latence en ms
  success           Boolean  @default(true)
  errorMessage      String?
  createdAt         DateTime @default(now())

  // Relations
  user            users?           @relation("UserLlmUsageLogs", fields: [userId], references: [id], onDelete: Cascade)
  userLlmProvider UserLlmProvider? @relation("ProviderUsageLogs", fields: [userLlmProviderId], references: [id], onDelete: SetNull)

  @@index([userId, createdAt])
  @@index([userLlmProviderId, createdAt])
  @@index([provider, createdAt])
  @@index([operationType])
  @@index([userId, operationType, createdAt])
  @@index([success, createdAt])
  @@index([operationType, success])
  @@map("llm_usage_logs")
}

model ProviderPerformance {
  id                String    @id @default(cuid())
  userId            String
  userLlmProviderId String? // FK vers UserLlmProvider (optionnel)
  provider          String
  avgLatency        Int       @default(0) // Latence moyenne (ms)
  successRate       Float     @default(100) // Taux de succès (0-100%)
  totalCalls        Int       @default(0)
  totalTokens       Int       @default(0)
  totalCost         Float     @default(0)
  lastUsed          DateTime?
  updatedAt         DateTime  @updatedAt

  // Relations
  user            users            @relation("UserProviderPerformance", fields: [userId], references: [id], onDelete: Cascade)
  userLlmProvider UserLlmProvider? @relation("ProviderMetrics", fields: [userLlmProviderId], references: [id], onDelete: SetNull)

  @@unique([userId, provider])
  @@index([avgLatency])
  @@index([successRate])
  @@index([userId, updatedAt])
  @@map("provider_performance")
}

