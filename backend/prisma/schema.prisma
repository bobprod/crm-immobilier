  errorCode      String?
  errorMessage   String?
  createdAt      DateTime             @default(now())
  updatedAt      DateTime             @updatedAt
  conversation   WhatsAppConversation @relation("ConversationMessages", fields: [conversationId], references: [id], onDelete: Cascade)
  sender         users?               @relation("UserWhatsAppMessages", fields: [sentBy], references: [id])

  @@index([conversationId])
  @@index([messageId])
  @@index([direction])
  @@index([timestamp])
  @@map("whatsapp_messages")
}

model WhatsAppTemplate {
  id             String             @id @default(cuid())
  configId       String
  name           String
  language       String             @default("fr")
  category       TemplateCategory
  header         String?
  body           String
  footer         String?
  buttons        Json?
  variables      String[]
  status         TemplateStatus     @default(pending)
  approvedAt     DateTime?
  rejectedReason String?
  sentCount      Int                @default(0)
  deliveredCount Int                @default(0)
  readCount      Int                @default(0)
  failedCount    Int                @default(0)
  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt
  campaigns      WhatsAppCampaign[] @relation("TemplateCampaigns")
  config         WhatsAppConfig     @relation("ConfigTemplates", fields: [configId], references: [id], onDelete: Cascade)

  @@unique([configId, name])
  @@index([configId])
  @@index([status])
  @@index([category])
  @@map("whatsapp_templates")
}

model WhatsAppContact {
  id                  String         @id @default(cuid())
  configId            String
  phoneNumber         String
  name                String?
  email               String?
  profilePicture      String?
  tags                String[]       @default([])
  groups              String[]       @default([])
  notes               String?
  customFields        Json?
  isBlocked           Boolean        @default(false)
  totalMessages       Int            @default(0)
  sentMessages        Int            @default(0)
  receivedMessages    Int            @default(0)
  totalConversations  Int            @default(0)
  activeConversations Int            @default(0)
  avgResponseTime     Int            @default(0)
  lastInteractionAt   DateTime?
  lastMessageAt       DateTime?
  createdAt           DateTime       @default(now())
  updatedAt           DateTime       @updatedAt
  config              WhatsAppConfig @relation("ConfigContacts", fields: [configId], references: [id], onDelete: Cascade)

  @@unique([configId, phoneNumber])
  @@index([configId])
  @@index([phoneNumber])
  @@index([isBlocked])
  @@index([tags])
  @@index([groups])
  @@map("whatsapp_contacts")
}

model WhatsAppCampaign {
  id              String                      @id @default(cuid())
  configId        String
  name            String
  description     String?
  type            CampaignType
  status          CampaignStatus              @default(draft)
  templateId      String
  templateName    String
  scheduledAt     DateTime?
  startedAt       DateTime?
  completedAt     DateTime?
  pausedAt        DateTime?
  cancelledAt     DateTime?
  totalRecipients Int                         @default(0)
  sentCount       Int                         @default(0)
  deliveredCount  Int                         @default(0)
  readCount       Int                         @default(0)
  failedCount     Int                         @default(0)
  pendingCount    Int                         @default(0)
  createdBy       String
  createdAt       DateTime                    @default(now())
  updatedAt       DateTime                    @updatedAt
  recipients      WhatsAppCampaignRecipient[] @relation("CampaignRecipients")
  config          WhatsAppConfig              @relation("ConfigCampaigns", fields: [configId], references: [id], onDelete: Cascade)
  template        WhatsAppTemplate            @relation("TemplateCampaigns", fields: [templateId], references: [id])

  @@index([configId])
  @@index([status])
  @@index([type])
  @@index([templateId])
  @@index([scheduledAt])
  @@map("whatsapp_campaigns")
}

model WhatsAppCampaignRecipient {
  id           String           @id @default(cuid())
  campaignId   String
  contactId    String?
  phoneNumber  String
  name         String?
  variables    Json?
  status       RecipientStatus  @default(pending)
  sentAt       DateTime?
  deliveredAt  DateTime?
  readAt       DateTime?
  failedAt     DateTime?
  errorMessage String?
  messageId    String?
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt
  campaign     WhatsAppCampaign @relation("CampaignRecipients", fields: [campaignId], references: [id], onDelete: Cascade)

  @@index([campaignId])
  @@index([status])
  @@index([phoneNumber])
  @@map("whatsapp_campaign_recipients")
}

model HeatmapEvent {
  id           String   @id @default(cuid())
  userId       String
  pageUrl      String
  x            Int
  y            Int
  type         String
  sessionId    String
  deviceType   String   @default("desktop")
  screenWidth  Int      @default(1920)
  screenHeight Int      @default(1080)
  element      String?
  userAgent    String?
  timestamp    DateTime @default(now())

  @@index([userId, pageUrl, type])
  @@index([sessionId])
  @@index([pageUrl])
  @@index([timestamp])
  @@map("heatmap_events")
}

model TrackingABTest {
  id             String                     @id @default(cuid())
  userId         String
  name           String
  description    String?
  variantAConfig Json
  variantBConfig Json
  trafficSplit   Int                        @default(50)
  startDate      DateTime
  endDate        DateTime
  status         String                     @default("running")
  createdAt      DateTime                   @default(now())
  updatedAt      DateTime                   @updatedAt
  assignments    TrackingABTestAssignment[]
  results        TrackingABTestResult[]

  @@index([userId])
  @@index([status])
  @@index([startDate, endDate])
  @@map("tracking_ab_tests")
}

model TrackingABTestAssignment {
  testId    String
  sessionId String
  variant   String
  createdAt DateTime       @default(now())
  test      TrackingABTest @relation(fields: [testId], references: [id], onDelete: Cascade)

  @@id([testId, sessionId])
  @@index([sessionId])
  @@map("tracking_ab_test_assignments")
}

model TrackingABTestResult {
  id        String         @id @default(cuid())
  testId    String
  sessionId String
  variant   String
  eventName String
  value     Float?
  timestamp DateTime       @default(now())
  test      TrackingABTest @relation(fields: [testId], references: [id], onDelete: Cascade)

  @@index([testId, variant])
  @@index([sessionId])
  @@index([eventName])
  @@map("tracking_ab_test_results")
}

