model prospecting_leads {
  id                 String           @id @default(cuid())
  campaignId         String
  userId             String
  firstName          String?
  lastName           String?
  email              String?
  phone              String?
  address            String?
  city               String?
  zipCode            String?
  country            String?          @default("Tunisie")
  propertyType       String?
  propertyTypes      String[] // Array of property types from LLM
  source             String?
  sourceUrl          String?
  rawText            String?          @db.Text // Original scraped text
  title              String? // Title from scraped content
  score              Int              @default(0)
  status             LeadStatus       @default(new)
  leadType           LeadType         @default(inconnu)
  intention          Intention?
  urgency            Urgency?
  validationStatus   ValidationStatus @default(pending)
  seriousnessScore   Int? // 0-100 from LLM analysis
  surfaceM2          Int? // Surface in square meters
  rooms              Int? // Number of rooms
  budgetMin          Float? // Minimum budget
  budgetMax          Float? // Maximum budget
  budgetCurrency     String?          @default("TND")
  qualificationNotes String?          @db.Text // Notes de qualification du lead

  // ✅ NOUVEAUX CHAMPS TRACKING
  retryCount      Int       @default(0) // Nombre de tentatives de contact
  lastContactedAt DateTime? // Dernière tentative de contact
  nextActionDate  DateTime? // Prochaine action planifiée
  sourceMetadata  Json? // Métadonnées du scraping
  qualityScore    Int? // Score qualité 0-100
  aiModelVersion  String? // Version du modèle LLM utilisé

  // ⚠️ DEPRECATED FIELDS - À SUPPRIMER DANS PROCHAINE VERSION
  prospectType       String? // @deprecated - Use leadType
  subType            String? // @deprecated
  searchCriteria     Json? // @deprecated
  mandatInfo         Json? // @deprecated
  profiling          Json? // @deprecated
  timeline           String? // @deprecated - Use urgency
  budget             Json? // @deprecated - Use budgetMin/budgetMax
  matchedPropertyIds String[] // @deprecated - Use prospecting_lead_properties junction table

  metadata              Json?
  convertedProspectId   String?
  convertedAt           DateTime?
  createdAt             DateTime                      @default(now())
  updatedAt             DateTime                      @updatedAt
  campaigns             prospecting_campaigns         @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  convertedProspect     prospects?                    @relation("ConvertedProspect", fields: [convertedProspectId], references: [id])
  users                 users                         @relation("UserProspectingLeads", fields: [userId], references: [id], onDelete: Cascade)
  prospecting_matches   prospecting_matches[]         @relation("LeadMatches")
  matchedProperties     prospecting_lead_properties[] @relation("LeadPropertyMatches")
  whatsappConversations WhatsAppConversation[]        @relation("LeadWhatsAppConversations")

  @@index([campaignId])
  @@index([userId])
  @@index([status])
  @@index([score])
  @@index([email])
  @@index([leadType])
  @@index([validationStatus])
  @@index([city])
  @@index([campaignId, status, leadType])
  @@index([userId, createdAt, status])
  @@index([validationStatus, createdAt])
  @@index([intention, urgency, city])
}

model prospecting_matches {
  id          String      @id @default(cuid())
  leadId      String
  prospectId  String?
  propertyId  String
  score       Int
  reason      Json // MatchReason structure from matching algorithm
  status      MatchStatus @default(pending)
  isQualified Boolean     @default(false) // score >= 50

  // ✅ NOUVEAUX CHAMPS TRACKING
  convertedAt     DateTime? // Date de conversion en prospect/client
  conversionValue Float? // Valeur de la conversion (€)
  attemptCount    Int       @default(1) // Nombre de tentatives de contact
  lastAttemptAt   DateTime? // Dernière tentative
  feedbackScore   Int? // Note de satisfaction (1-5)

  // ⚠️ DEPRECATED FIELDS - À SUPPRIMER DANS PROCHAINE VERSION
  prospectType   String? // @deprecated - Use lead.leadType
  subType        String? // @deprecated
  searchCriteria Json? // @deprecated
  mandatInfo     Json? // @deprecated
  profiling      Json? // @deprecated
  timeline       String? // @deprecated - Use lead.urgency
  budget         Json? // @deprecated - Use lead.budgetMin/budgetMax

  // Tracking existant
  notifiedAt  DateTime?
  contactedAt DateTime?
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt
  // Relations
  lead        prospecting_leads @relation("LeadMatches", fields: [leadId], references: [id], onDelete: Cascade)
  properties  properties        @relation("PropertyMatches", fields: [propertyId], references: [id], onDelete: Cascade)
  prospects   prospects?        @relation("ProspectMatches", fields: [prospectId], references: [id])

  @@unique([leadId, propertyId])
  @@index([leadId])
  @@index([prospectId])
  @@index([propertyId])
  @@index([score])
  @@index([status])
  @@index([isQualified])
  @@index([status, isQualified, createdAt])
  @@index([score, status])
  @@index([propertyId, status])
}

// Table de junction pour remplacer matchedPropertyIds[] dans prospecting_leads
// Permet de créer une vraie relation many-to-many avec indexes efficaces
model prospecting_lead_properties {
  id         String   @id @default(cuid())
  leadId     String
  propertyId String
  matchScore Int      @default(0) // Score spécifique de ce match (0-100)
  matchedAt  DateTime @default(now())
  createdAt  DateTime @default(now())

  // Relations
  lead     prospecting_leads @relation("LeadPropertyMatches", fields: [leadId], references: [id], onDelete: Cascade)
  property properties        @relation("PropertyLeadMatches", fields: [propertyId], references: [id], onDelete: Cascade)

  @@unique([leadId, propertyId])
  @@index([leadId, matchScore])
  @@index([propertyId, matchScore])
  @@index([matchedAt])
  @@map("prospecting_lead_properties")
}

