model Notification {
  id        String    @id @default(cuid())
  userId    String
  type      String    // appointment, task, lead, system, property, message
  title     String
  message   String    @db.Text
  actionUrl String?
  metadata  Json?     @default("{}")
  isRead    Boolean   @default(false)
  readAt    DateTime?
  deletedAt DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  user users @relation("UserNotifications", fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([isRead])
  @@index([type])
  @@index([createdAt])
  @@index([deletedAt])
  @@map("notifications")
}

// ============================================
// 🆕 SYNC LOGS MODULE (NOUVEAU)
// ============================================

model SyncLog {
  id           String   @id @default(cuid())
  entityType   String   // property, prospect, appointment, etc.
  entityId     String
  platform     String   // wordpress, facebook, google, etc.
  status       String   // success, error, pending
  externalId   String?
  errorMessage String?  @db.Text
  syncedAt     DateTime @default(now())
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([entityType, entityId])
  @@index([platform])
  @@index([status])
  @@index([syncedAt])
  @@map("sync_logs")
}

// ============================================
// 🆕 ACTIVITY LOGS MODULE (NOUVEAU)
// ============================================

model Activity {
  id          String   @id @default(cuid())
  userId      String
  type        String   // property_created, prospect_contacted, appointment_scheduled, etc.
  description String
  entityType  String?  // property, prospect, appointment, etc.
  entityId    String?
  metadata    Json?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user users @relation("UserActivities", fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([type])
  @@index([createdAt])
  @@index([entityType, entityId])
  @@map("activities")
}

// ============================================
// 🆕 PROPERTY HISTORY MODULE
// ============================================

model PropertyHistory {
  id         String     @id @default(cuid())
  propertyId String
  userId     String
  action     String     // create, update, delete, restore, status_changed
  changes    Json?      // Changed fields with before/after values
  metadata   Json?      // Additional metadata
  createdAt  DateTime   @default(now())
  
  property   properties @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  
  @@index([propertyId])
  @@index([userId])
  @@index([action])
  @@index([createdAt])
  @@map("property_history")
}

// ============================================
// 🆕 EMAIL AI AUTO-RESPONSE MODULE
// ============================================

model EmailAIAnalysis {
  id                String    @id @default(cuid())
  userId            String
  from              String    // Sender email
  subject           String
  body              String    @db.Text
  prospectId        String?
  propertyId        String?
  intent            String    // information, appointment, negotiation, complaint, other
  confidence        Int       // 0-100
  keywords          Json?     // Array of keywords
  suggestedActions  Json?     // Array of suggested actions
  context           Json?     // Gathered context
  status            String    @default("analyzed") // analyzed, draft_generated, completed
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  user              users             @relation("EmailAIAnalyses", fields: [userId], references: [id], onDelete: Cascade)
  prospects         prospects?        @relation("EmailAIProspect", fields: [prospectId], references: [id], onDelete: SetNull)
  properties        properties?       @relation("EmailAIProperty", fields: [propertyId], references: [id], onDelete: SetNull)
  email_ai_drafts   EmailAIDraft[]

  @@index([userId])
  @@index([prospectId])
  @@index([propertyId])
  @@index([intent])
  @@index([status])
  @@index([createdAt])
  @@map("email_ai_analyses")
}

model EmailAIDraft {
  id                    String    @id @default(cuid())
  userId                String
  analysisId            String
  to                    String
  subject               String
  body                  String    @db.Text
  attachmentSuggestions Json?     // Array of suggested attachments
  status                String    @default("pending") // pending, sent, failed
  sentAt                DateTime?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  user                  users            @relation("EmailAIDrafts", fields: [userId], references: [id], onDelete: Cascade)
  email_ai_analyses     EmailAIAnalysis  @relation(fields: [analysisId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([analysisId])
  @@index([status])
  @@index([createdAt])
  @@map("email_ai_drafts")
}

// ============================================
// AI CHAT ASSISTANT - Conversational AI tables
// ============================================

model AIChatConversation {
  id        String    @id @default(cuid())
  userId    String
  title     String    @default("Nouvelle conversation")
  context   Json?     // Conversation context/metadata
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  user      users            @relation("AIChatConversations", fields: [userId], references: [id], onDelete: Cascade)
  messages  AIChatMessage[]

  @@index([userId])
  @@index([deletedAt])
  @@index([updatedAt])
  @@map("ai_chat_conversations")
}

model AIChatMessage {
  id             String   @id @default(cuid())
  conversationId String
  role           String   // user, assistant, system
  content        String   @db.Text
  metadata       Json?    // Intent, confidence, tokens, etc.
  createdAt      DateTime @default(now())

  conversation   AIChatConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([conversationId])
  @@index([createdAt])
  @@map("ai_chat_messages")
}
