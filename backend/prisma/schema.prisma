// ============================================
// MODELS
// ============================================

model ProspectingSource {
  id          String    @id @default(cuid())
  name        String
  url         String?
  type        String
  config      Json?
  lastScraped DateTime?
  isActive    Boolean   @default(true)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model agencies {
  id         String       @id @default(cuid())
  name       String
  address    String?
  phone      String?
  email      String?
  createdAt  DateTime     @default(now())
  updatedAt  DateTime     @updatedAt
  properties properties[]
  prospects  prospects[]
  users      users[]

  // ── Nouvelles relations AI Billing ──
  apiKeys     AgencyApiKeys?
  aiCredits   AiCredits?
  aiUsages    AiUsage[]
  aiErrorLogs AiErrorLog[]

  // ── Nouvelles relations Module Registry (Phase 1) ──
  moduleSubscriptions ModuleAgencySubscription[]

  // ── Nouvelles relations Provider Registry (Phase 1) ──
  providerConfigs ProviderConfig[] @relation("AgencyProviders")

  // ── Nouvelles relations WhatsApp ──
  whatsappConfigs       WhatsAppConfig[]       @relation("AgencyWhatsAppConfig")
  whatsappConversations WhatsAppConversation[] @relation("AgencyWhatsAppConversations")
}

model appointments {
  id             String      @id @default(cuid())
  userId         String
  prospectId     String?
  propertyId     String?
  title          String
  description    String?
  startTime      DateTime
  endTime        DateTime
  location       String?
  type           String      @default("visit")
  status         String      @default("scheduled")
  prospectType   String?
  subType        String?
  searchCriteria Json?
  mandatInfo     Json?
  profiling      Json?
  timeline       String?
  budget         Json?
  priority       String      @default("medium")
  isAllDay       Boolean     @default(false)
  reminder       Boolean     @default(true)
  reminderSent   Boolean     @default(false)
  reminderTime   Int?        @default(60)
  attendees      Json?
  notes          String?
  outcome        String?
  rating         Int?
  googleEventId  String?
  iCalUid        String?
  recurrence     Json?
  color          String?     @default("#3B82F6")
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt
  properties     properties? @relation(fields: [propertyId], references: [id])
  prospects      prospects?  @relation(fields: [prospectId], references: [id])
  users          users       @relation(fields: [userId], references: [id], onDelete: Cascade)
  tasks          tasks[]     @relation("AppointmentTasks")

  @@index([userId])
  @@index([prospectId])
  @@index([propertyId])
  @@index([startTime])
  @@index([status])
  @@index([type])
}

model campaigns {
  id             String    @id @default(cuid())
  userId         String
  name           String
  description    String?
  type           String
  status         String    @default("draft")
  prospectType   String?
  subType        String?
  searchCriteria Json?
  mandatInfo     Json?
  profiling      Json?
  timeline       String?
  budget         Json?
  content        Json
  recipients     Json
  scheduledAt    DateTime?
  sentAt         DateTime?
  stats          Json?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  users          users     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model matches {
  id             String     @id @default(cuid())
  propertyId     String
  prospectId     String
  score          Float
  reasons        Json?
  status         String     @default("pending")
  prospectType   String?
  subType        String?
  searchCriteria Json?
  mandatInfo     Json?
  profiling      Json?
  timeline       String?
  budget         Json?
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt
  properties     properties @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  prospects      prospects  @relation(fields: [prospectId], references: [id], onDelete: Cascade)

  @@unique([propertyId, prospectId])
}

model properties {
  id             String           @id @default(cuid())
  userId         String
  agencyId       String?
  reference      String?
  title          String
  description    String?
  type           String // PropertyType as string for flexibility
  category       PropertyCategory @default(sale)
  price          Float
  currency       String           @default("TND")
  address        String?
  city           String?
  delegation     String?
  zipCode        String?
  latitude       Float?
  longitude      Float?
  bedrooms       Int?
  bathrooms      Int?
  area           Float?
  images         String[] // Array of image URLs
  features       String[] // Array of feature strings
  status         PropertyStatus   @default(available)
  viewsCount     Int              @default(0)
  // DEPRECATED: These fields couple properties to prospecting domain
  // Should be moved to prospecting_matches or a separate junction table
  // TODO: Migrate data and remove in future version
  prospectType   String? // @deprecated - use prospecting_leads.leadType
  subType        String? // @deprecated
  searchCriteria Json? // @deprecated - use prospecting_leads criteria
  mandatInfo     Json? // @deprecated - use prospecting_leads.metadata
  profiling      Json? // @deprecated
  timeline       String? // @deprecated - use prospecting_leads.urgency
  budget         Json? // @deprecated - use prospecting_leads.budget*
  wpSyncId       String?
  wpSyncedAt     DateTime?
  wordpressId    String?
  deletedAt      DateTime? // Soft delete timestamp
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt

  // Relations
  history             PropertyHistory[]
  propertySeo         PropertySeo?
  publishedProperty   PublishedProperty[]
  vitrineAnalytics    VitrineAnalytics[]
  appointments        appointments[]
  communications      communications[]
  documents           documents[]
  matches             matches[]
  agencies            agencies?                     @relation(fields: [agencyId], references: [id])
  users               users                         @relation(fields: [userId], references: [id], onDelete: Cascade)
  prospectShown       prospect_properties_shown[]   @relation("PropertyProspectShown")
  prospecting_matches prospecting_matches[]         @relation("PropertyMatches")
  matchedLeads        prospecting_lead_properties[] @relation("PropertyLeadMatches")
  tasks               tasks[]                       @relation("PropertyTasks")

  // Priority & Organization
  priority      PropertyPriority @default(medium)
  tags          String[] // Array of tag strings
  assignedTo    String?
  isFeatured    Boolean          @default(false)
  notes         String?
  lastContactAt DateTime?
  assignedUser  users?           @relation("AssignedProperties", fields: [assignedTo], references: [id])

  // Owner/Vendor (deprecated - use ownerNew)
  ownerId String?
  owner   prospects? @relation("PropertyOwner", fields: [ownerId], references: [id])

  // New Owner relation
  ownerNewId String?
  ownerNew   Owner?  @relation("OwnerProperties", fields: [ownerNewId], references: [id])

  // Business relations
  mandates     Mandate[]     @relation("PropertyMandates")
  transactions Transaction[] @relation("PropertyTransactions")

  // Financials
  netPrice       Float?
  fees           Float?
  feesPercentage Float?

  @@index([priority])
  @@index([isFeatured])
  @@index([assignedTo])
  @@index([ownerId])
  @@index([ownerNewId])
  // Indexes for matching performance
  @@index([price])
  @@index([city])
  @@index([type])
  @@index([status])
  @@index([deletedAt])
  @@index([userId, status, price]) // Composite for matching queries
}

// ============================================
// PropertyHistory - Track all property changes
// ============================================
model PropertyHistory {
  id         String   @id @default(cuid())
  propertyId String
  userId     String
  action     String
  changes    Json?
  metadata   Json?
  createdAt  DateTime @default(now())

  property properties @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  user     users      @relation("PropertyHistory", fields: [userId], references: [id], onDelete: Cascade)

  @@index([propertyId])
  @@index([userId])
  @@index([action])
  @@index([createdAt])
  @@map("property_history")
}

model prospects {
  id                   String                      @id @default(cuid())
  userId               String
  agencyId             String?
  firstName            String?
  lastName             String?
  email                String?
  phone                String?
  type                 String
  currency             String                      @default("TND")
  preferences          Json?
  source               String?
  status               String                      @default("active")
  score                Int                         @default(0)
  prospectType         String?
  subType              String?
  searchCriteria       Json?
  mandatInfo           Json?
  profiling            Json?
  timeline             String?
  budget               Json?
  notes                String?
  deletedAt            DateTime?
  createdAt            DateTime                    @default(now())
  updatedAt            DateTime                    @updatedAt
  appointments         appointments[]
  communications       communications[]
  contact_validations  contact_validations[]       @relation("ProspectValidations")
  documents            documents[]
  matches              matches[]
  interactions         prospect_interactions[]     @relation("ProspectInteractions")
  preferences_details  prospect_preferences[]      @relation("ProspectPreferences")
  propertiesShown      prospect_properties_shown[] @relation("ProspectPropertiesShown")
  timelineStages       prospect_timeline[]         @relation("ProspectTimeline")
  converted_from_leads prospecting_leads[]         @relation("ConvertedProspect")
  prospecting_matches  prospecting_matches[]       @relation("ProspectMatches")
  agencies             agencies?                   @relation(fields: [agencyId], references: [id])
  users                users                       @relation(fields: [userId], references: [id], onDelete: Cascade)
  tasks                tasks[]                     @relation("ProspectTasks")
  ownedProperties      properties[]                @relation("PropertyOwner")
  transactions         Transaction[]               @relation("ProspectTransactions")
  prospectHistory      ProspectHistory[]
}

// ============================================
// ProspectHistory - Track all prospect changes
// ============================================
model ProspectHistory {
  id         String   @id @default(cuid())
  prospectId String
  userId     String
  action     String
  changes    Json
  metadata   Json?
  createdAt  DateTime @default(now())

  prospect prospects @relation(fields: [prospectId], references: [id], onDelete: Cascade)
  user     users     @relation("UserProspectHistory", fields: [userId], references: [id], onDelete: Cascade)

  @@index([prospectId])
  @@index([userId])
  @@index([action])
  @@index([createdAt])
  @@map("prospect_history")
}

// ════════════════════════════════════════════════════════════
// USER ROLES ENUM - SAAS CORE OS
// ════════════════════════════════════════════════════════════
enum UserRole {
  USER // Utilisateur simple (ex: freelance, client final)
  AGENT // Agent métier (immo, voyage, recruteur)
  ADMIN // Admin agence
  SUPER_ADMIN // Admin plateforme
}

model users {
  id                      String                    @id @default(cuid())
  email                   String                    @unique
  password                String
  firstName               String?
  lastName                String?
  role                    UserRole                  @default(AGENT)
  agencyId                String?
  createdAt               DateTime                  @default(now())
  updatedAt               DateTime                  @updatedAt
  aiSuggestions           AiSuggestion[]
  detectedAnomalies       DetectedAnomaly[]
  llmConfig               LlmConfig?
  mlConfig                MlConfig?
  pages                   Page[]
  publishedProperties     PublishedProperty[]
  seoBlogPosts            SeoBlogPost[]
  seoConfig               SeoConfig?
  trackingConfigs         TrackingConfig[]
  trackingEvents          TrackingEvent[]
  vitrineAnalytics        VitrineAnalytics[]
  vitrineConfig           VitrineConfig?
  ai_generations          ai_generations[]          @relation("UserAiGenerations")
  ai_settings             ai_settings?
  ai_usage_metrics        ai_usage_metrics[]        @relation("UserAiUsageMetrics")
  analytics_events        analytics_events[]        @relation("UserAnalyticsEvents")
  appointments            appointments[]
  campaigns               campaigns[]
  communication_templates communication_templates[] @relation("UserCommunicationTemplates")
  communications          communications[]          @relation("UserCommunications")
  contact_validations     contact_validations[]     @relation("UserContactValidations")
  conversion_events       conversion_events[]       @relation("UserConversionEvents")
  document_templates      document_templates[]      @relation("UserDocumentTemplates")
  documents               documents[]               @relation("UserDocuments")
  ocr_results             ocr_results[]             @relation("UserOcrResults")
  properties              properties[]
  prospect_interactions   prospect_interactions[]   @relation("UserProspectInteractions")
  prospecting_campaigns   prospecting_campaigns[]   @relation("UserProspectingCampaigns")
  prospecting_leads       prospecting_leads[]       @relation("UserProspectingLeads")
  prospects               prospects[]
  prospectHistory         ProspectHistory[]         @relation("UserProspectHistory")
  propertyHistory         PropertyHistory[]         @relation("PropertyHistory")
  settings                settings[]                @relation("UserSettings")
  tasks                   tasks[]                   @relation("UserTasks")
  userIntegrations        UserIntegration[]         @relation("UserIntegrations")
  aiOrchestrations        AiOrchestration[]
  toolCallLogs            ToolCallLog[]
  agencies                agencies?                 @relation(fields: [agencyId], references: [id])
  assignedProperties      properties[]              @relation("AssignedProperties")
  notifications           Notification[]            @relation("UserNotifications")
  notificationPreferences NotificationPreference?   @relation("UserNotificationPreferences")
  activities              Activity[]                @relation("UserActivities")
  owners                  Owner[]                   @relation("UserOwners")
  mandates                Mandate[]                 @relation("UserMandates")
  transactions            Transaction[]             @relation("UserTransactions")
  commissions             Commission[]              @relation("UserCommissions")
  agentCommissions        Commission[]              @relation("AgentCommissions")
  invoices                Invoice[]                 @relation("UserInvoices")
  payments                Payment[]                 @relation("UserPayments")
  wordpressUrl            String?
  wordpressUsername       String?
  wordpressPassword       String?

  // ── Nouvelles relations AI Billing ──
  aiUsages      AiUsage[]
  aiErrorLogs   AiErrorLog[]
  userAiCredits UserAiCredits?

  // ── Nouvelles relations Provider Registry (Phase 1) ──
  providerConfigs ProviderConfig[] @relation("UserProviders")

  // ── Nouvelles relations LLM & WhatsApp ──
  userLlmProviders      UserLlmProvider[]
  llmUsageLogs          LlmUsageLog[]          @relation("UserLlmUsageLogs")
  providerPerformances  ProviderPerformance[]  @relation("UserProviderPerformance")
  whatsappConfigs       WhatsAppConfig[]       @relation("UserWhatsAppConfig")
  whatsappConversations WhatsAppConversation[] @relation("UserWhatsAppConversations")
  whatsappMessages      WhatsAppMessage[]      @relation("UserWhatsAppMessages")
}

model communications {
  id             String                   @id @default(cuid())
  userId         String
  type           String
  to             String
  from           String?
  subject        String?
  body           String
  status         String                   @default("sent")
  prospectType   String?
  subType        String?
  searchCriteria Json?
  mandatInfo     Json?
  profiling      Json?
  timeline       String?
  budget         Json?
  sentAt         DateTime                 @default(now())
  deliveredAt    DateTime?
  openedAt       DateTime?
  clickedAt      DateTime?
  failedReason   String?
  prospectId     String?
  propertyId     String?
  templateId     String?
  metadata       Json?
  createdAt      DateTime                 @default(now())
  updatedAt      DateTime                 @updatedAt
  properties     properties?              @relation(fields: [propertyId], references: [id])
  prospects      prospects?               @relation(fields: [prospectId], references: [id])
  template       communication_templates? @relation(fields: [templateId], references: [id])
  users          users                    @relation("UserCommunications", fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([prospectId])
  @@index([type])
  @@index([status])
}

model communication_templates {
  id             String           @id @default(cuid())
  userId         String
  name           String
  type           String
  subject        String?
  content        String
  variables      Json
  isActive       Boolean          @default(true)
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt
  users          users            @relation("UserCommunicationTemplates", fields: [userId], references: [id], onDelete: Cascade)
  communications communications[]

  @@index([userId])
  @@index([type])
}

model document_categories {
  id          String                @id @default(cuid())
  name        String
  description String?
  color       String?
  icon        String?
  parentId    String?
  createdAt   DateTime              @default(now())
  updatedAt   DateTime              @updatedAt
  parent      document_categories?  @relation("CategoryHierarchy", fields: [parentId], references: [id])
  children    document_categories[] @relation("CategoryHierarchy")
  documents   documents[]

  @@index([parentId])
}

model documents {
  id             String               @id @default(cuid())
  userId         String
  categoryId     String?
  name           String
  originalName   String
  description    String?
  fileUrl        String
  filePath       String
  mimeType       String
  fileSize       Int
  extension      String
  prospectId     String?
  propertyId     String?
  relatedType    String?
  relatedId      String?
  tags           Json?
  metadata       Json?
  isTemplate     Boolean              @default(false)
  isPublic       Boolean              @default(false)
  isSigned       Boolean              @default(false)
  signedAt       DateTime?
  signedBy       String?
  ocrProcessed   Boolean              @default(false)
  ocrText        String?
  aiGenerated    Boolean              @default(false)
  aiGenerationId String?
  version        Int                  @default(1)
  createdAt      DateTime             @default(now())
  updatedAt      DateTime             @updatedAt
  aiGeneration   ai_generations?      @relation(fields: [aiGenerationId], references: [id])
  category       document_categories? @relation(fields: [categoryId], references: [id])
  properties     properties?          @relation(fields: [propertyId], references: [id])
  prospects      prospects?           @relation(fields: [prospectId], references: [id])
  users          users                @relation("UserDocuments", fields: [userId], references: [id], onDelete: Cascade)
  ocr_results    ocr_results[]

  @@index([userId])
  @@index([categoryId])
  @@index([prospectId])
  @@index([propertyId])
  @@index([relatedType, relatedId])
}

model document_templates {
  id          String   @id @default(cuid())
  userId      String
  name        String
  description String?
  content     String
  variables   Json
  category    String?
  mimeType    String   @default("text/html")
  isActive    Boolean  @default(true)
  isPublic    Boolean  @default(false)
  usageCount  Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  users       users    @relation("UserDocumentTemplates", fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([category])
}

model ai_generations {
  id             String      @id @default(cuid())
  userId         String
  provider       String
  model          String
  prompt         String
  response       String
  type           String?
  documentType   String?
  tokensUsed     Int?
  cost           Float?
  temperature    Float?
  maxTokens      Int?
  status         String      @default("completed")
  prospectType   String?
  subType        String?
  searchCriteria Json?
  mandatInfo     Json?
  profiling      Json?
  timeline       String?
  budget         Json?
  errorMessage   String?
  metadata       Json?
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt
  users          users       @relation("UserAiGenerations", fields: [userId], references: [id], onDelete: Cascade)
  documents      documents[]

  @@index([userId])
  @@index([provider])
  @@index([status])
}

model ocr_results {
  id             String     @id @default(cuid())
  userId         String
  documentId     String?
  imageUrl       String
  extractedText  String
  text           String?
