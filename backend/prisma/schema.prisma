// ============================================================
// MODULE PERSONNEL - Gestion agents, commerciaux et personnel
// ============================================================

model AgentProfile {
  id            String   @id @default(cuid())
  userId        String   @unique
  agencyId      String
  jobTitle      String?
  phone         String?
  hireDate      DateTime?
  isActive      Boolean  @default(true)
  notes         String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  user          users    @relation(fields: [userId], references: [id], onDelete: Cascade)
  agency        agencies @relation(fields: [agencyId], references: [id], onDelete: Cascade)
  commissionOverride AgentCommissionOverride?
  monthlyPerformances AgentMonthlyPerformance[]

  @@index([agencyId])
  @@map("agent_profiles")
}

// Commission tiers configurables par agence (par le manager)
model CommissionConfig {
  id                String   @id @default(cuid())
  agencyId          String   @unique
  tier1MaxAmount    Float    @default(4000)
  tier2MinAmount    Float    @default(7000)
  tier2Rate         Float    @default(15)
  tier3MinAmount    Float    @default(11000)
  tier3Rate         Float    @default(20)
  directSaleRate    Float    @default(20)
  currency          String   @default("TND")
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  agency            agencies @relation(fields: [agencyId], references: [id], onDelete: Cascade)

  @@map("commission_configs")
}

// Override de commission pour un agent spécifique
model AgentCommissionOverride {
  id              String   @id @default(cuid())
  agentProfileId  String   @unique
  tier1MaxAmount  Float?
  tier2MinAmount  Float?
  tier2Rate       Float?
  tier3MinAmount  Float?
  tier3Rate       Float?
  directSaleRate  Float?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  agentProfile    AgentProfile @relation(fields: [agentProfileId], references: [id], onDelete: Cascade)

  @@map("agent_commission_overrides")
}

// Configuration prime de fin d'année par agence
model AnnualBonusConfig {
  id              String   @id @default(cuid())
  agencyId        String   @unique
  tier1MinAmount  Float    @default(180000)
  tier1Rate       Float    @default(5)
  tier2MinAmount  Float?
  tier2Rate       Float?
  tier3MinAmount  Float?
  tier3Rate       Float?
  currency        String   @default("TND")
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  agency          agencies @relation(fields: [agencyId], references: [id], onDelete: Cascade)

  @@map("annual_bonus_configs")
}

// Performance mensuelle par agent
model AgentMonthlyPerformance {
  id                    String   @id @default(cuid())
  agentProfileId        String
  year                  Int
  month                 Int
  caAmount              Float    @default(0)
  commissionRate        Float    @default(0)
  commissionAmount      Float    @default(0)
  directSalesCA         Float    @default(0)
  directSalesCommission Float    @default(0)
  totalCommission       Float    @default(0)
  currency              String   @default("TND")
  notes                 String?
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  agentProfile    AgentProfile @relation(fields: [agentProfileId], references: [id], onDelete: Cascade)

  @@unique([agentProfileId, year, month])
  @@index([agentProfileId])
  @@index([year, month])
  @@map("agent_monthly_performances")
}
