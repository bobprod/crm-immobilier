{
  "$schema": "https://app.kilo.ai/config.json",
  "mcp": {
    "context7": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "@upstash/context7-mcp"
      ],
      "environment": {
        "DEFAULT_MINIMUM_TOKENS": "{{DEFAULT_MINIMUM_TOKENS}}"
      }
    },
    "filesystem": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "@modelcontextprotocol/server-filesystem",
        "C:\\Users\\BOB\\Desktop\\project dev"
      ]
    },
    "firebase": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "firebase-tools@14.15.2",
        "experimental:mcp"
      ]
    },
    "fireproof": {
      "type": "local",
      "command": [
        "node",
        "{{FIREPROOF_PATH}}/build/index.js"
      ]
    },
    "laravel-boost": {
      "type": "local",
      "command": [
        "php",
        "artisan",
        "boost:mcp"
      ]
    },
    "google-maps-platform-code-assist": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "@googlemaps/code-assist-mcp@0.2.0"
      ]
    },
    "memory": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "@modelcontextprotocol/server-memory"
      ]
    }
  }
}
