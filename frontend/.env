# ============================================
# FRONTEND CONFIGURATION
# ============================================

# API Backend URL
NEXT_PUBLIC_API_URL=http://localhost:3000

# App URL
NEXT_PUBLIC_APP_URL=http://localhost:3003

# Environment
NODE_ENV=development

# ============================================
# OPTIONAL SERVICES
# ============================================

# Google Maps (pour géolocalisation des biens)
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=

# Google Analytics (pour tracking)
NEXT_PUBLIC_ANALYTICS_ID=

# ============================================
# NOTES
# ============================================
# Ce fichier contient les variables d'environnement du frontend
# Ne jamais commiter ce fichier avec des clés API réelles !
