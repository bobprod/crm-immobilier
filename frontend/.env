# ============================================
# FRONTEND CONFIGURATION
# ============================================

# API Backend URL
NEXT_PUBLIC_API_URL=http://localhost:3001/api

# App URL
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Environment
NODE_ENV=development

# ============================================
# OPTIONAL SERVICES
# ============================================

# Google Maps (pour géolocalisation des biens)
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=

# Google Analytics (pour tracking)
NEXT_PUBLIC_ANALYTICS_ID=

# ============================================
# TEST CREDENTIALS
# ============================================
# Credentials for E2E tests (Playwright)
TEST_USER_EMAIL=amine@example.com
TEST_USER_PASSWORD=Test1234

# ============================================
# NOTES
# ============================================
# Ce fichier contient les variables d'environnement du frontend
# Ne jamais commiter ce fichier avec des clés API réelles !
