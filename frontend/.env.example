# API Backend URL
NEXT_PUBLIC_API_URL=http://localhost:3000/api

# Environment
NODE_ENV=development

# App URL
NEXT_PUBLIC_APP_URL=http://localhost:3001

# Google Maps (optionnel pour géolocalisation)
