# =============================================================
# CRM IMMO SAAS — ENVIRONMENT VARIABLES TEMPLATE
# Copy this file to backend/.env and fill in real values
# NEVER commit the actual .env file to git
# =============================================================

# ---------------------------
# DATABASE (PostgreSQL)
# ---------------------------
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/crm_immobilier?schema=public"

# ---------------------------
# SERVER
# ---------------------------
PORT=3000
NODE_ENV=development         # development | production | test

# ---------------------------
# JWT AUTHENTICATION  ← Required by invoice module
# ---------------------------
JWT_SECRET=                  # Min 32 chars, random string
JWT_EXPIRES_IN=7d            # Access token expiry
JWT_REFRESH_SECRET=          # Different from JWT_SECRET
JWT_REFRESH_EXPIRES_IN=30d   # Refresh token expiry

# ---------------------------
# CORS & FRONTEND
# ---------------------------
FRONTEND_URL=http://localhost:3003
CORS_ORIGIN=http://localhost:3003

# ---------------------------
# RATE LIMITING
# ---------------------------
THROTTLE_TTL=60000           # Window in ms (60 seconds)
THROTTLE_LIMIT=60            # Max requests per window

# ---------------------------
# GOOGLE OAUTH
# ---------------------------
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:3000/api/auth/google/callback

# ---------------------------
# FACEBOOK OAUTH
# ---------------------------
FACEBOOK_APP_ID=
FACEBOOK_APP_SECRET=
FACEBOOK_CALLBACK_URL=http://localhost:3000/api/auth/facebook/callback

# ---------------------------
# EMAIL / SMTP
# ---------------------------
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USER=
MAIL_PASSWORD=
MAIL_FROM=noreply@crm-immobilier.com

# ---------------------------
# SMS — TWILIO
# ---------------------------
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# ---------------------------
# LLM / AI PROVIDERS  (at least 1 required)
# ---------------------------
ANTHROPIC_API_KEY=           # Recommended
OPENAI_API_KEY=
GOOGLE_AI_API_KEY=
DEEPSEEK_API_KEY=
OPENROUTER_API_KEY=

# ---------------------------
# WORDPRESS INTEGRATION  (optional)
# ---------------------------
WORDPRESS_API_URL=
WORDPRESS_USERNAME=
WORDPRESS_APP_PASSWORD=

# ---------------------------
# MARKETING PIXELS  (all optional)
# ---------------------------
FACEBOOK_PIXEL_ID=
FACEBOOK_CONVERSION_API_TOKEN=
FACEBOOK_TEST_EVENT_CODE=
GOOGLE_TAG_MANAGER_ID=
GTM_SERVER_CONTAINER_URL=
GTM_SERVER_CONTAINER_ID=
GA4_MEASUREMENT_ID=
GA4_API_SECRET=
GOOGLE_ADS_CONVERSION_ID=
GOOGLE_ADS_CONVERSION_LABEL_LEAD=
GOOGLE_ADS_CONVERSION_LABEL_PURCHASE=
GOOGLE_ADS_CONVERSION_LABEL_SCHEDULE=
GOOGLE_ADS_CONVERSION_LABEL_CONTACT=
TIKTOK_PIXEL_ID=
TIKTOK_ACCESS_TOKEN=
LINKEDIN_PARTNER_ID=
LINKEDIN_CONVERSION_ID_LEAD=
LINKEDIN_CONVERSION_ID_CONTACT=
LINKEDIN_CONVERSION_ID_DOWNLOAD=
LINKEDIN_ACCESS_TOKEN=
SERVER_SIDE_PROVIDER=none    # none | stape | gtm_server | segment | custom
STAPE_CONTAINER_URL=
STAPE_API_KEY=

# =============================================================
# MINIMUM REQUIRED for invoice module to work:
#   DATABASE_URL, JWT_SECRET, JWT_REFRESH_SECRET, PORT, NODE_ENV
# =============================================================
